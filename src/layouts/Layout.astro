---
import '../styles/global.css'

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Molt Code is the harness your AI coding agents need. It gives Claude, Codex, and Gemini the structure, context, and coordination to actually ship — using your own API keys. Free desktop app." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google Analytics -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-GPY1Q2VV2W"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-GPY1Q2VV2W');
    </script>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0b0907" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#faf7f4" media="(prefers-color-scheme: light)" />
    <meta name="apple-itunes-app" content="app-id=6760204854" />

    <!-- Prevent flash of wrong theme -->
    <script is:inline>
      (function() {
        var stored = localStorage.getItem('theme');
        if (stored === 'light' || stored === 'dark') {
          document.documentElement.setAttribute('data-theme', stored);
        } else if (window.matchMedia('(prefers-color-scheme: light)').matches) {
          document.documentElement.setAttribute('data-theme', 'light');
        } else {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>

    <!-- Platform detection — before first paint -->
    <script is:inline>
      (function() {
        var ua = navigator.userAgent;
        var p = 'mac-arm';
        if (/iPhone|iPod/.test(ua) || /iPad/.test(ua) ||
            (/Macintosh/.test(ua) && navigator.maxTouchPoints > 1)) {
          p = 'ios';
        }
        document.documentElement.setAttribute('data-platform', p);
      })();
    </script>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://moltcode.com" />
    <meta property="og:image" content="https://moltcode.com/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://moltcode.com/og-image.png" />

    <meta name="apple-itunes-app" content="app-id=6760204854" />
    <meta name="application-name" content="Molt Code" />
    <meta property="og:site_name" content="Molt Code" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="canonical" href={`https://moltcode.com${Astro.url.pathname}`} />
    <title>{title}</title>

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "SoftwareApplication",
          "name": "Molt Code",
          "alternateName": "MoltCode",
          "url": "https://moltcode.com",
          "applicationCategory": "DeveloperApplication",
          "operatingSystem": "macOS",
          "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
          "description": description,
          "screenshot": "https://moltcode.com/og-image.png",
          "softwareVersion": "0.0.54",
          "downloadUrl": "https://github.com/moltcode/moltcode/releases",
          "author": { "@type": "Organization", "name": "Molt Code", "url": "https://moltcode.com" }
        },
        {
          "@type": "WebSite",
          "name": "Molt Code",
          "url": "https://moltcode.com"
        },
        {
          "@type": "Organization",
          "name": "Molt Code",
          "url": "https://moltcode.com",
          "logo": "https://moltcode.com/favicon.svg",
          "sameAs": ["https://moltcode.com"]
        }
      ]
    })} />
  </head>
  <body class="gradient-bg noise-overlay relative min-h-screen antialiased">
    <canvas id="grid-canvas" class="grid-canvas"></canvas>
    <div class="easter-egg-hint" id="easter-egg-hint" aria-label="Hidden game hint">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
      <span>Click rapidly anywhere to start a game</span>
    </div>
    <slot />

    <style>
      .grid-canvas {
        position: fixed;
        inset: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 0;
      }

      .easter-egg-hint {
        position: fixed;
        bottom: 1.25rem;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        border-radius: 9999px;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        color: var(--color-secondary);
        font-size: 0.6875rem;
        font-family: var(--font-family-mono);
        letter-spacing: 0.02em;
        opacity: 0;
        z-index: 40;
        pointer-events: none;
        transition: opacity 0.4s ease;
        white-space: nowrap;
      }

      .easter-egg-hint.visible {
        opacity: 0.6;
        pointer-events: auto;
      }

      .easter-egg-hint:hover {
        opacity: 0.9;
      }

      .easter-egg-hint svg {
        color: var(--color-accent);
        opacity: 0.7;
        flex-shrink: 0;
      }
    </style>

    <script>
      const canvas = document.getElementById('grid-canvas') as HTMLCanvasElement;
      const ctx = canvas.getContext('2d');
      const CELL = 60;
      const RADIUS = 200;
      let mouseX = -1000;
      let mouseY = -1000;
      let animId: number;

      // Ripples: expanding rings from click points
      interface Ripple { x: number; y: number; radius: number; maxRadius: number; born: number; colorIdx: number; }
      const ripples: Ripple[] = [];
      const RIPPLE_SPEED = 400;
      const RIPPLE_MAX = 600;
      const RIPPLE_BAND = 120;

      const COLORS = [
        [231, 159, 116], // copper
        [116, 185, 231], // blue
        [165, 116, 231], // purple
        [231, 116, 165], // pink
        [116, 231, 165], // green
        [231, 210, 116], // gold
        [116, 210, 231], // cyan
      ];
      let clickCount = 0;

      // ── Game state ──
      type GameState = 'IDLE' | 'TRANSITIONING_IN' | 'PLAYING' | 'GAME_OVER' | 'TRANSITIONING_OUT';
      let gameState: GameState = 'IDLE';
      const clickTimestamps: number[] = [];
      const RAPID_TOTAL = 12; // clicks needed in window
      const RAPID_WINDOW = 3000; // 3s window

      interface Ghost {
        x: number; y: number;
        color: number[];
        speed: number;
      }
      interface Coin { cellX: number; cellY: number; spawnTime: number; }

      let playerCellX = 0;
      let playerCellY = 0;
      let coin: Coin | null = null;
      let ghosts: Ghost[] = [];
      let score = 0;
      let gameOverTime = 0;
      let gameStartTime = 0;
      let lastGhostSpawn = 0;
      let lastFrameTime = 0;
      const MAX_GHOSTS = 8;

      // ── Canvas resize ──
      function resize() {
        const dpr = window.devicePixelRatio || 1;
        canvas.width = window.innerWidth * dpr;
        canvas.height = window.innerHeight * dpr;
        canvas.style.width = window.innerWidth + 'px';
        canvas.style.height = window.innerHeight + 'px';
        ctx?.scale(dpr, dpr);
      }

      // ── Spawn helpers ──
      function spawnCoin() {
        const cols = Math.floor(window.innerWidth / CELL);
        const rows = Math.floor(window.innerHeight / CELL);
        let cx: number, cy: number;
        do {
          cx = Math.floor(Math.random() * cols);
          cy = Math.floor(Math.random() * rows);
        } while (Math.abs(cx - playerCellX) + Math.abs(cy - playerCellY) < 6);
        coin = { cellX: cx, cellY: cy, spawnTime: performance.now() };
      }

      function spawnGhost() {
        const w = window.innerWidth;
        const h = window.innerHeight;
        const cols = Math.floor(w / CELL);
        const rows = Math.floor(h / CELL);
        const edge = Math.floor(Math.random() * 4);
        let gx: number, gy: number;
        if (edge === 0) { gx = Math.random() * w; gy = 0; }
        else if (edge === 1) { gx = Math.random() * w; gy = h; }
        else if (edge === 2) { gx = 0; gy = Math.random() * h; }
        else { gx = w; gy = Math.random() * h; }
        ghosts.push({
          x: gx, y: gy,
          color: COLORS[Math.floor(Math.random() * COLORS.length)],
          speed: 30,
        });
      }

      // ── Transition helpers ──
      function startTransitionIn() {
        gameState = 'TRANSITIONING_IN';
        canvas.style.pointerEvents = 'auto';
        canvas.style.zIndex = '9999';
        canvas.style.cursor = 'none';
        document.body.style.overflow = 'hidden';

        const els = document.querySelectorAll('body > *:not(#grid-canvas)');
        els.forEach(el => {
          const h = el as HTMLElement;
          h.style.transition = 'opacity 0.8s ease-out';
          h.style.opacity = '0';
          h.style.pointerEvents = 'none';
        });

        setTimeout(() => {
          gameState = 'PLAYING';
          score = 0;
          ghosts = [];
          coin = null;
          const now = performance.now();
          gameStartTime = now;
          lastGhostSpawn = now;
          lastFrameTime = now;
          playerCellX = Math.floor(mouseX / CELL);
          playerCellY = Math.floor(mouseY / CELL);
          spawnCoin();
        }, 800);
      }

      function startTransitionOut() {
        gameState = 'TRANSITIONING_OUT';
        canvas.style.pointerEvents = 'none';
        canvas.style.zIndex = '0';
        canvas.style.cursor = '';
        document.body.style.overflow = '';

        const els = document.querySelectorAll('body > *:not(#grid-canvas)');
        els.forEach(el => {
          const h = el as HTMLElement;
          h.style.transition = 'opacity 0.8s ease-in';
          h.style.opacity = '1';
          h.style.pointerEvents = '';
        });

        ghosts = [];
        coin = null;
        ripples.length = 0;
        clickTimestamps.length = 0;

        setTimeout(() => { gameState = 'IDLE'; }, 800);
      }

      // ── Ambient peeking ghosts ──
      interface PeekGhost {
        edge: number;       // 0=top, 1=right, 2=bottom, 3=left
        pos: number;        // position along edge (px)
        color: number[];
        born: number;
        duration: number;   // how long the full peek cycle lasts
        peekDist: number;   // how far it peeks in (px)
      }
      const peekGhosts: PeekGhost[] = [];
      let lastPeekSpawn = performance.now();
      const PEEK_INTERVAL = 3000; // new ghost every 3s
      const PEEK_SIZE = 40;       // slightly smaller than game ghosts

      function spawnPeekGhost(now: number) {
        const w = window.innerWidth;
        const h = window.innerHeight;
        const edge = Math.floor(Math.random() * 4);
        let pos: number;
        if (edge === 0 || edge === 2) pos = PEEK_SIZE + Math.random() * (w - PEEK_SIZE * 2);
        else pos = PEEK_SIZE + Math.random() * (h - PEEK_SIZE * 2);
        peekGhosts.push({
          edge,
          pos,
          color: COLORS[Math.floor(Math.random() * COLORS.length)],
          born: now,
          duration: 3000 + Math.random() * 2000,
          peekDist: 20 + Math.random() * 20,
        });
      }

      function drawPeekGhost(pg: PeekGhost, now: number, isDark: boolean) {
        if (!ctx) return;
        const t = (now - pg.born) / pg.duration;
        if (t > 1) return;

        // Ease in then ease out
        const peek = Math.sin(t * Math.PI);
        const dist = peek * pg.peekDist;
        if (dist < 2) return;

        const w = window.innerWidth;
        const h = window.innerHeight;
        let gx: number, gy: number;

        if (pg.edge === 0) { gx = pg.pos - PEEK_SIZE / 2; gy = -PEEK_SIZE + dist; }
        else if (pg.edge === 1) { gx = w - dist; gy = pg.pos - PEEK_SIZE / 2; }
        else if (pg.edge === 2) { gx = pg.pos - PEEK_SIZE / 2; gy = h - dist; }
        else { gx = -PEEK_SIZE + dist; gy = pg.pos - PEEK_SIZE / 2; }

        const gc = pg.color;
        const alpha = peek * 0.6;

        // Body
        ctx.fillStyle = `rgba(${gc[0]}, ${gc[1]}, ${gc[2]}, ${alpha})`;
        ctx.fillRect(gx + 2, gy + 2, PEEK_SIZE - 4, PEEK_SIZE - 4);

        // Wavy bottom
        ctx.fillStyle = isDark ? `rgba(11, 9, 7, ${alpha})` : `rgba(250, 247, 244, ${alpha})`;
        const waveEdge = pg.edge === 0 ? gy + PEEK_SIZE - 6 : pg.edge === 2 ? gy + 2 : gy + PEEK_SIZE - 6;
        for (let i = 0; i < 2; i++) {
          const wx = gx + 4 + i * 14;
          ctx.beginPath();
          ctx.arc(wx + 7, waveEdge, 5, 0, Math.PI);
          ctx.fill();
        }

        // Eyes — looking inward toward center of page
        const eyeAlpha = Math.min(alpha + 0.2, 0.9);
        ctx.fillStyle = `rgba(255, 255, 255, ${eyeAlpha})`;
        const eyeS = 6;
        const eyeGap = 10;
        const ex1 = gx + PEEK_SIZE / 2 - eyeGap / 2 - eyeS;
        const ex2 = gx + PEEK_SIZE / 2 + eyeGap / 2;
        const ey = gy + PEEK_SIZE * 0.3;
        ctx.fillRect(ex1, ey, eyeS, eyeS);
        ctx.fillRect(ex2, ey, eyeS, eyeS);

        // Pupils — stare toward page center
        const centerX = w / 2;
        const centerY = h / 2;
        const dirX = Math.sign(centerX - gx);
        const dirY = Math.sign(centerY - gy);
        ctx.fillStyle = `rgba(17, 17, 17, ${eyeAlpha})`;
        const ps = 3;
        ctx.fillRect(ex1 + 1.5 + dirX * 1.5, ey + 1.5 + dirY * 1.5, ps, ps);
        ctx.fillRect(ex2 + 1.5 + dirX * 1.5, ey + 1.5 + dirY * 1.5, ps, ps);
      }

      // ── Normal grid drawing ──
      function drawGrid(w: number, h: number, now: number) {
        const isDark = document.documentElement.getAttribute('data-theme') !== 'light';
        const r = isDark ? 231 : 0;
        const g = isDark ? 159 : 0;
        const b = isDark ? 116 : 0;

        // Advance ripples
        for (let i = ripples.length - 1; i >= 0; i--) {
          const rip = ripples[i];
          rip.radius = ((now - rip.born) / 1000) * RIPPLE_SPEED;
          if (rip.radius > rip.maxRadius + RIPPLE_BAND) ripples.splice(i, 1);
        }

        const cols = Math.ceil(w / CELL) + 1;
        const rows = Math.ceil(h / CELL) + 1;

        for (let row = 0; row < rows; row++) {
          for (let col = 0; col < cols; col++) {
            const x = col * CELL;
            const y = row * CELL;
            const cx = x + CELL / 2;
            const cy = y + CELL / 2;

            const dx = cx - mouseX;
            const dy = cy - mouseY;
            const dist = Math.sqrt(dx * dx + dy * dy);
            const t = Math.max(0, 1 - dist / RADIUS);
            if (t > 0) {
              const alpha = t * t * (isDark ? 0.06 : 0.04);
              ctx!.fillStyle = `rgba(${r}, ${g}, ${b}, ${alpha})`;
              ctx!.fillRect(x, y, CELL, CELL);
            }

            for (const rip of ripples) {
              const rdx = cx - rip.x;
              const rdy = cy - rip.y;
              const rdist = Math.sqrt(rdx * rdx + rdy * rdy);
              const distFromRing = Math.abs(rdist - rip.radius);
              if (distFromRing < RIPPLE_BAND) {
                const ringT = 1 - distFromRing / RIPPLE_BAND;
                const life = 1 - rip.radius / (rip.maxRadius + RIPPLE_BAND);
                const ripAlpha = ringT * life * (isDark ? 0.12 : 0.08);
                const rc = COLORS[rip.colorIdx];
                ctx!.fillStyle = `rgba(${rc[0]}, ${rc[1]}, ${rc[2]}, ${Math.min(ripAlpha, 0.4)})`;
                ctx!.fillRect(x, y, CELL, CELL);
              }
            }
          }
        }

        // Ambient peeking ghosts
        if (now - lastPeekSpawn > PEEK_INTERVAL) {
          spawnPeekGhost(now);
          lastPeekSpawn = now;
          // Keep max 4 at a time
          while (peekGhosts.length > 4) peekGhosts.shift();
        }
        // Remove expired
        for (let i = peekGhosts.length - 1; i >= 0; i--) {
          if (now - peekGhosts[i].born > peekGhosts[i].duration) peekGhosts.splice(i, 1);
        }
        // Draw them
        for (const pg of peekGhosts) {
          drawPeekGhost(pg, now, isDark);
        }
      }

      // ── Game drawing ──
      function drawGame(w: number, h: number, now: number) {
        const isDark = document.documentElement.getAttribute('data-theme') !== 'light';
        const dt = (now - lastFrameTime) / 1000;
        lastFrameTime = now;

        // Update player
        playerCellX = Math.max(0, Math.floor(mouseX / CELL));
        playerCellY = Math.max(0, Math.floor(mouseY / CELL));

        // Click rate
        const recentClicks = clickTimestamps.filter(t => now - t < 1000).length;

        // Spawn ghosts
        const spawnInterval = Math.max(2000, 4000 - score * 200);
        if (now - lastGhostSpawn > spawnInterval && ghosts.length < MAX_GHOSTS && now - gameStartTime > 2000) {
          spawnGhost();
          lastGhostSpawn = now;
        }

        // Move ghosts — faster when clicks slow down, with separation so they don't stack
        const clickRatio = Math.min(recentClicks / 4, 1);
        const SEPARATION_RADIUS = CELL * 2.5;
        const SEPARATION_FORCE = 120;

        for (let gi = 0; gi < ghosts.length; gi++) {
          const ghost = ghosts[gi];
          ghost.speed = 40 + (1 - clickRatio) * 280;

          // Chase player
          const tx = playerCellX * CELL + CELL / 2;
          const ty = playerCellY * CELL + CELL / 2;
          let gdx = tx - ghost.x;
          let gdy = ty - ghost.y;
          const gDist = Math.sqrt(gdx * gdx + gdy * gdy);
          let moveX = 0;
          let moveY = 0;
          if (gDist > 1) {
            moveX = (gdx / gDist) * ghost.speed;
            moveY = (gdy / gDist) * ghost.speed;
          }

          // Separation from other ghosts
          let sepX = 0;
          let sepY = 0;
          for (let gj = 0; gj < ghosts.length; gj++) {
            if (gi === gj) continue;
            const other = ghosts[gj];
            const sx = ghost.x - other.x;
            const sy = ghost.y - other.y;
            const sDist = Math.sqrt(sx * sx + sy * sy);
            if (sDist < SEPARATION_RADIUS && sDist > 0.1) {
              const strength = (1 - sDist / SEPARATION_RADIUS);
              sepX += (sx / sDist) * SEPARATION_FORCE * strength;
              sepY += (sy / sDist) * SEPARATION_FORCE * strength;
            }
          }

          ghost.x += (moveX + sepX) * dt;
          ghost.y += (moveY + sepY) * dt;

          // Keep ghosts in bounds
          ghost.x = Math.max(0, Math.min(ghost.x, w));
          ghost.y = Math.max(0, Math.min(ghost.y, h));
        }

        // Check ghost collision
        for (const ghost of ghosts) {
          if (Math.floor(ghost.x / CELL) === playerCellX && Math.floor(ghost.y / CELL) === playerCellY) {
            gameState = 'GAME_OVER';
            gameOverTime = now;
            return;
          }
        }

        // Check coin collection
        if (coin && playerCellX === coin.cellX && playerCellY === coin.cellY) {
          score++;
          spawnCoin();
          if (ghosts.length < MAX_GHOSTS) spawnGhost();
        }

        // ── Render ──
        // Background
        ctx!.fillStyle = isDark ? '#0b0907' : '#faf7f4';
        ctx!.fillRect(0, 0, w, h);

        // Grid lines
        ctx!.strokeStyle = isDark ? 'rgba(231, 159, 116, 0.04)' : 'rgba(0, 0, 0, 0.04)';
        ctx!.lineWidth = 1;
        for (let x = 0; x <= w; x += CELL) {
          ctx!.beginPath(); ctx!.moveTo(x, 0); ctx!.lineTo(x, h); ctx!.stroke();
        }
        for (let y = 0; y <= h; y += CELL) {
          ctx!.beginPath(); ctx!.moveTo(0, y); ctx!.lineTo(w, y); ctx!.stroke();
        }

        // Coin
        if (coin) {
          const pulse = Math.sin(now / 300) * 0.3 + 0.7;
          const coinX = coin.cellX * CELL;
          const coinY = coin.cellY * CELL;
          ctx!.save();
          ctx!.shadowColor = 'rgba(231, 210, 116, 0.7)';
          ctx!.shadowBlur = 25 * pulse;
          ctx!.fillStyle = `rgba(231, 210, 116, ${pulse})`;
          ctx!.fillRect(coinX + 6, coinY + 6, CELL - 12, CELL - 12);
          ctx!.restore();
        }

        // Ghosts
        for (const ghost of ghosts) {
          const gx = Math.floor(ghost.x / CELL) * CELL;
          const gy = Math.floor(ghost.y / CELL) * CELL;
          const gc = ghost.color;

          // Body
          ctx!.fillStyle = `rgba(${gc[0]}, ${gc[1]}, ${gc[2]}, 0.85)`;
          ctx!.fillRect(gx + 3, gy + 3, CELL - 6, CELL - 6);

          // Wavy bottom edge (pac-man ghost style)
          ctx!.fillStyle = isDark ? '#0b0907' : '#faf7f4';
          const waveY = gy + CELL - 8;
          for (let i = 0; i < 3; i++) {
            const wx = gx + 5 + i * 17;
            ctx!.beginPath();
            ctx!.arc(wx + 8, waveY, 6, 0, Math.PI);
            ctx!.fill();
          }

          // Eyes
          ctx!.fillStyle = 'white';
          ctx!.fillRect(gx + 14, gy + 16, 10, 10);
          ctx!.fillRect(gx + 34, gy + 16, 10, 10);

          // Pupils — look toward player
          const dirX = Math.sign(playerCellX * CELL - ghost.x);
          const dirY = Math.sign(playerCellY * CELL - ghost.y);
          ctx!.fillStyle = '#111';
          ctx!.fillRect(gx + 16 + dirX * 3, gy + 18 + dirY * 3, 6, 6);
          ctx!.fillRect(gx + 36 + dirX * 3, gy + 18 + dirY * 3, 6, 6);
        }

        // Player
        const pc = COLORS[clickCount % COLORS.length];
        const px = playerCellX * CELL;
        const py = playerCellY * CELL;
        ctx!.save();
        ctx!.shadowColor = `rgba(${pc[0]}, ${pc[1]}, ${pc[2]}, 0.9)`;
        ctx!.shadowBlur = 18;
        ctx!.fillStyle = `rgb(${pc[0]}, ${pc[1]}, ${pc[2]})`;
        ctx!.fillRect(px + 5, py + 5, CELL - 10, CELL - 10);
        ctx!.restore();

        // Score HUD
        ctx!.font = 'bold 20px monospace';
        ctx!.fillStyle = isDark ? 'rgba(231, 159, 116, 0.9)' : 'rgba(120, 80, 50, 0.9)';
        ctx!.textAlign = 'center';
        ctx!.fillText(`SCORE: ${score}`, w / 2, 44);

        // Click rate bar
        const barW = 160;
        const barH = 6;
        const barX = w / 2 - barW / 2;
        const barY = h - 36;
        const fill = Math.min(clickRatio, 1);
        ctx!.fillStyle = 'rgba(255,255,255,0.08)';
        ctx!.fillRect(barX, barY, barW, barH);
        ctx!.fillStyle = fill >= 0.8 ? 'rgba(116, 231, 165, 0.7)' : fill >= 0.4 ? 'rgba(231, 210, 116, 0.7)' : 'rgba(231, 116, 116, 0.7)';
        ctx!.fillRect(barX, barY, barW * fill, barH);

        ctx!.font = '11px monospace';
        ctx!.fillStyle = isDark ? 'rgba(244, 233, 223, 0.4)' : 'rgba(26, 21, 18, 0.4)';
        ctx!.fillText('CLICK SPEED', w / 2, barY + barH + 16);
      }

      // ── Game over overlay ──
      function drawGameOver(w: number, h: number, now: number) {
        const isDark = document.documentElement.getAttribute('data-theme') !== 'light';

        // Draw frozen game state underneath
        ctx!.fillStyle = isDark ? '#0b0907' : '#faf7f4';
        ctx!.fillRect(0, 0, w, h);

        // Grid lines
        ctx!.strokeStyle = isDark ? 'rgba(231, 159, 116, 0.04)' : 'rgba(0, 0, 0, 0.04)';
        ctx!.lineWidth = 1;
        for (let x = 0; x <= w; x += CELL) {
          ctx!.beginPath(); ctx!.moveTo(x, 0); ctx!.lineTo(x, h); ctx!.stroke();
        }
        for (let y = 0; y <= h; y += CELL) {
          ctx!.beginPath(); ctx!.moveTo(0, y); ctx!.lineTo(w, y); ctx!.stroke();
        }

        // Draw ghosts frozen
        for (const ghost of ghosts) {
          const gx = Math.floor(ghost.x / CELL) * CELL;
          const gy = Math.floor(ghost.y / CELL) * CELL;
          const gc = ghost.color;
          ctx!.fillStyle = `rgba(${gc[0]}, ${gc[1]}, ${gc[2]}, 0.4)`;
          ctx!.fillRect(gx + 3, gy + 3, CELL - 6, CELL - 6);
        }

        // Overlay
        const fadeIn = Math.min((now - gameOverTime) / 600, 1);
        ctx!.fillStyle = isDark ? `rgba(11, 9, 7, ${0.85 * fadeIn})` : `rgba(250, 247, 244, ${0.85 * fadeIn})`;
        ctx!.fillRect(0, 0, w, h);

        if (fadeIn < 0.3) return;
        const textAlpha = Math.min((fadeIn - 0.3) / 0.7, 1);

        ctx!.globalAlpha = textAlpha;

        // Flash the player cell red
        const px = playerCellX * CELL;
        const py = playerCellY * CELL;
        const flash = Math.sin(now / 150) * 0.3 + 0.5;
        ctx!.fillStyle = `rgba(231, 80, 80, ${flash * textAlpha})`;
        ctx!.fillRect(px + 2, py + 2, CELL - 4, CELL - 4);

        ctx!.font = 'bold 52px monospace';
        ctx!.fillStyle = isDark ? '#e79f74' : '#8b5a3a';
        ctx!.textAlign = 'center';
        ctx!.fillText('GAME OVER', w / 2, h / 2 - 36);

        ctx!.font = 'bold 30px monospace';
        ctx!.fillText(`${score}`, w / 2, h / 2 + 16);

        ctx!.font = '14px monospace';
        ctx!.fillStyle = isDark ? 'rgba(244, 233, 223, 0.5)' : 'rgba(26, 21, 18, 0.5)';

        if (now - gameOverTime > 1500) {
          ctx!.fillText('click to continue', w / 2, h / 2 + 60);
        }

        ctx!.globalAlpha = 1;
      }

      // ── Main draw loop ──
      function draw() {
        if (!ctx) return;
        const w = window.innerWidth;
        const h = window.innerHeight;
        const now = performance.now();
        ctx.clearRect(0, 0, w, h);

        if (gameState === 'PLAYING') {
          drawGame(w, h, now);
        } else if (gameState === 'GAME_OVER') {
          drawGameOver(w, h, now);
        } else {
          drawGrid(w, h, now);
        }

        animId = requestAnimationFrame(draw);
      }

      // ── Event handlers ──
      function onMouseMove(e: MouseEvent) {
        mouseX = e.clientX;
        mouseY = e.clientY;
      }

      function onMouseLeave() {
        if (gameState === 'IDLE') {
          mouseX = -1000;
          mouseY = -1000;
        }
      }

      function onClick(e: MouseEvent) {
        const now = performance.now();
        clickTimestamps.push(now);
        // Prune old timestamps
        while (clickTimestamps.length > 0 && now - clickTimestamps[0] > 4000) {
          clickTimestamps.shift();
        }

        if (gameState === 'IDLE') {
          // Normal ripple
          ripples.push({
            x: e.clientX, y: e.clientY,
            radius: 0, maxRadius: RIPPLE_MAX,
            born: now, colorIdx: clickCount % COLORS.length,
          });
          clickCount++;

          // Check for rapid clicking to trigger game
          const recent = clickTimestamps.filter(t => now - t < RAPID_WINDOW);
          if (recent.length >= RAPID_TOTAL) {
            startTransitionIn();
          }
        } else if (gameState === 'PLAYING') {
          clickCount++;
        } else if (gameState === 'GAME_OVER') {
          if (now - gameOverTime > 1500) {
            startTransitionOut();
          }
        }
      }

      // ── Easter egg hint ──
      const hintEl = document.getElementById('easter-egg-hint');
      let hintShown = false;
      let hintDismissed = false;
      let idleClickCount = 0;

      function maybeShowHint() {
        if (hintShown || hintDismissed || !hintEl) return;
        // Show after user has clicked a few times (they're exploring)
        if (idleClickCount >= 3) {
          hintEl.classList.add('visible');
          hintShown = true;
          // Auto-hide after 8s if not interacted
          setTimeout(() => {
            if (hintEl && gameState === 'IDLE') {
              hintEl.classList.remove('visible');
              hintDismissed = true;
            }
          }, 8000);
        }
      }

      function hideHint() {
        if (hintEl) hintEl.classList.remove('visible');
        hintDismissed = true;
      }

      // Track idle clicks for hint trigger
      const originalOnClick = onClick;
      function onClickWithHint(e: MouseEvent) {
        if (gameState === 'IDLE') {
          idleClickCount++;
          maybeShowHint();
        }
        if (gameState !== 'IDLE' || (gameState === 'IDLE' && clickTimestamps.filter(t => performance.now() - t < RAPID_WINDOW).length >= RAPID_TOTAL - 1)) {
          hideHint();
        }
        originalOnClick(e);
      }

      // ── Init ──
      resize();
      draw();
      window.addEventListener('resize', resize);
      document.addEventListener('mousemove', onMouseMove);
      document.addEventListener('mouseleave', onMouseLeave);
      document.addEventListener('click', onClickWithHint);
    </script>

    <!-- Download dropdown toggle -->
    <script>
      document.addEventListener('click', (e) => {
        const toggle = (e.target as Element).closest('[data-dl-toggle]');
        if (toggle) {
          e.stopPropagation();
          const cta = toggle.closest('[data-download-cta]');
          const dropdown = cta?.querySelector('[data-dl-dropdown]');
          // Close any other open dropdowns first
          document.querySelectorAll('[data-dl-dropdown].open').forEach(el => {
            if (el !== dropdown) el.classList.remove('open');
          });
          dropdown?.classList.toggle('open');
          return;
        }
        // Close all dropdowns when clicking outside
        document.querySelectorAll('[data-dl-dropdown].open').forEach(el => el.classList.remove('open'));
      });
    </script>

    <!-- Track download button clicks as virtual pageviews (uses Cloudflare auto-injected beacon) -->
    <script>
      document.querySelectorAll('[data-track-download]').forEach((el) => {
        el.addEventListener('click', () => {
          if (window.__cfBeacon && window.__cfBeacon.load) {
            window.__cfBeacon.load({ path: '/virtual/download-click' });
          }
        });
      });
    </script>
  </body>
</html>
