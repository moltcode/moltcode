---
const currentYear = new Date().getFullYear();
---

<footer class="py-12 px-6 border-t border-theme-border">
  <div class="max-w-5xl mx-auto">
    <div class="grid md:grid-cols-4 gap-10 mb-10">
      <!-- Brand -->
      <div class="md:col-span-2">
        <a href="/" class="flex items-center gap-3 mb-4">
          <svg width="32" height="32" viewBox="0 0 64 64" class="rounded-lg">
            <defs>
              <linearGradient id="footerBgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#27272a"/>
                <stop offset="100%" stop-color="#3f3f46"/>
              </linearGradient>
              <linearGradient id="footerCopperGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#b45309"/>
                <stop offset="50%" stop-color="#d97706"/>
                <stop offset="100%" stop-color="#92400e"/>
              </linearGradient>
              <linearGradient id="footerBronzeGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#f59e0b"/>
                <stop offset="100%" stop-color="#d97706"/>
              </linearGradient>
            </defs>
            <rect x="0" y="0" width="64" height="64" rx="14" fill="url(#footerBgGrad)"/>
            <rect x="12" y="30" width="16" height="24" rx="4" fill="url(#footerCopperGrad)"/>
            <rect x="34" y="20" width="16" height="34" rx="4" fill="url(#footerCopperGrad)" opacity="0.7"/>
            <rect x="24" y="10" width="16" height="28" rx="4" fill="url(#footerBronzeGrad)"/>
          </svg>
          <span class="text-lg font-semibold text-theme-primary">Molt Code</span>
        </a>
        <p class="text-sm text-theme-primary/40 max-w-sm leading-relaxed">
          Molt Code is the harness your AI coding agents need. Free forever. Bring your own API keys.
        </p>
      </div>

      <!-- Product -->
      <div>
        <h4 class="text-sm text-theme-primary font-medium mb-3">Product</h4>
        <ul class="space-y-2.5">
          <li><a href="#features" class="text-sm text-theme-primary/40 hover:text-theme-accent transition-colors">Features</a></li>
          <li><a href="/docs/what-is-moltcode" class="text-sm text-theme-primary/40 hover:text-theme-accent transition-colors">Docs</a></li>
          <li><a href="/docs/changelog" class="text-sm text-theme-primary/40 hover:text-theme-accent transition-colors">Changelog</a></li>
          <li><a href="/docs/support" class="text-sm text-theme-primary/40 hover:text-theme-accent transition-colors">Support</a></li>
        </ul>
      </div>

      <!-- Connect -->
      <div>
        <h4 class="text-sm text-theme-primary font-medium mb-3">Connect</h4>
        <ul class="space-y-2.5">
          <li>
            <a href="https://github.com/moltcode/moltcode/issues" target="_blank" class="text-sm text-theme-primary/40 hover:text-theme-accent transition-colors">
              Report Issues
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="flex flex-col md:flex-row items-center justify-between gap-4 pt-8 border-t border-theme-border">
      <p class="text-theme-primary/30 text-xs">
        &copy; {currentYear} Molt Code. A product from <a href="https://utpun.com" target="_blank" class="text-theme-primary/50 hover:text-theme-accent transition-colors">Utpun Tech Labs Pvt. Ltd.</a>
      </p>
      <div class="flex items-center gap-6">
        <a href="/privacy" class="text-theme-primary/30 hover:text-theme-primary/50 transition-colors text-xs">Privacy</a>
        <a href="/terms" class="text-theme-primary/30 hover:text-theme-primary/50 transition-colors text-xs">Terms</a>
      </div>
    </div>
  </div>
</footer>
