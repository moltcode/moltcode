---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="footer-name"><span class="footer-prompt">$</span> moltcode --version</div>
        <p class="footer-desc">
          The harness your AI coding agents need. Free forever. Bring your own API keys.
        </p>
      </div>

      <div class="footer-col">
        <div class="footer-heading">// product</div>
        <ul class="footer-list">
          <li><a href="/#features">features</a></li>
          <li><a href="/#workflow">workflow</a></li>
          <li><a href="/pricing/">pricing</a></li>
          <li><a href="/docs/what-is-moltcode/">docs</a></li>
          <li><a href="/docs/changelog/">changelog</a></li>
          <li><a href="/docs/support/">support</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <div class="footer-heading">// connect</div>
        <ul class="footer-list">
          <li><a href="https://github.com/moltcode/moltcode/issues" target="_blank">github.issues</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <span class="footer-copy">© {currentYear} molt code · <a href="https://utpun.com" target="_blank">utpun tech labs</a></span>
      <div class="footer-legal">
        <a href="/privacy/">privacy</a>
        <a href="/terms/">terms</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    margin-top: 4rem;
    padding: 3rem 1.25rem 2rem;
    font-family: var(--font-family-mono);
  }

  @media (min-width: 640px) {
    .footer {
      padding: 4rem 2rem 2rem;
    }
  }

  .footer-inner {
    max-width: 64rem;
    margin: 0 auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr;
    }
  }

  .footer-brand {
    max-width: 22rem;
  }

  .footer-name {
    font-size: 13px;
    color: var(--color-primary);
    margin-bottom: 0.625rem;
  }

  .footer-prompt {
    color: var(--color-accent);
    margin-right: 0.25rem;
  }

  .footer-desc {
    font-size: 12px;
    color: var(--color-secondary);
    line-height: 1.7;
    margin: 0;
  }

  .footer-heading {
    font-size: 11px;
    color: var(--color-muted);
    margin-bottom: 0.75rem;
    letter-spacing: 0.04em;
  }

  .footer-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-list a {
    font-size: 12px;
    color: var(--color-secondary);
    transition: color 120ms ease;
  }

  .footer-list a:hover {
    color: var(--color-accent);
  }

  .footer-bottom {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-top: 1.5rem;
    font-size: 11px;
    color: var(--color-muted);
  }

  @media (min-width: 640px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }

  .footer-copy a {
    color: var(--color-secondary);
    transition: color 120ms ease;
  }

  .footer-copy a:hover {
    color: var(--color-accent);
  }

  .footer-legal {
    display: flex;
    gap: 1.25rem;
  }

  .footer-legal a {
    color: var(--color-muted);
    transition: color 120ms ease;
  }

  .footer-legal a:hover {
    color: var(--color-accent);
  }
</style>
