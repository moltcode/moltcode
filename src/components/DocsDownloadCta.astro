---
import { config } from '../config';
import AppleIcon from './AppleIcon.astro';
---

<div class="docs-download-cta">
  <div class="cta-inner" data-download-cta>
    <p class="cta-text">Ready to try it yourself?</p>
    <div class="cta-right">
      <a href={config.downloadUrl} data-track-download data-dl="mac-arm" class="cta-download-btn">
        <AppleIcon size={18} />
        <span>Download for Mac (Apple Silicon)</span>
        <span class="cta-version">v{config.version}</span>
      </a>
      <a href={config.appStoreUrl} data-dl="ios" class="cta-download-btn">
        <AppleIcon size={18} />
        <span>iPhone & iPad</span>
      </a>
      <div class="cta-dl-more">
        <button type="button" class="cta-dl-toggle" data-dl-toggle>
          All downloads
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </button>
        <div class="cta-dl-dropdown" data-dl-dropdown>
          <a href={config.downloadUrl} data-track-download class="cta-dl-item">
            <AppleIcon size={14} />
            macOS — Apple Silicon
          </a>
          <a href={config.appStoreUrl} class="cta-dl-item">
            <AppleIcon size={14} />
            iPhone & iPad — App Store
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .docs-download-cta {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .cta-text {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-secondary);
  }

  .cta-right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .cta-download-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 600;
    color: white;
    background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-strong) 100%);
    box-shadow:
      0 0 0 1px rgba(var(--color-accent-rgb), 0.3),
      0 4px 12px rgba(var(--color-accent-rgb), 0.2);
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  .cta-download-btn:hover {
    transform: translateY(-1px);
    box-shadow:
      0 0 0 1px rgba(var(--color-accent-rgb), 0.4),
      0 8px 20px rgba(var(--color-accent-rgb), 0.3);
  }

  .cta-version {
    font-size: 0.75rem;
    font-weight: 400;
    opacity: 0.7;
  }

  /* Platform-based primary button visibility */
  [data-dl] {
    display: none;
  }

  :global([data-platform="mac-arm"]) [data-dl="mac-arm"],
  :global([data-platform="ios"]) [data-dl="ios"] {
    display: inline-flex;
  }

  .cta-dl-more {
    position: relative;
  }

  .cta-dl-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0;
    border: none;
    background: none;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-secondary);
    cursor: pointer;
    transition: color 0.2s ease;
    font-family: inherit;
    white-space: nowrap;
  }

  .cta-dl-toggle:hover {
    color: var(--text-primary);
  }

  .cta-dl-dropdown {
    display: none;
    position: absolute;
    bottom: calc(100% + 0.5rem);
    right: 0;
    flex-direction: column;
    min-width: 13rem;
    padding: 0.375rem;
    border-radius: 0.75rem;
    background: var(--color-surface-solid);
    border: 1px solid var(--color-border);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
    z-index: 999;
  }

  .cta-dl-dropdown:global(.open) {
    display: flex;
  }

  .cta-dl-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    border-radius: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-primary);
    text-decoration: none;
    transition: background 0.15s ease;
    white-space: nowrap;
  }

  .cta-dl-item:hover {
    background: rgba(var(--color-accent-rgb), 0.08);
  }

  @media (max-width: 480px) {
    .cta-inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .cta-right {
      flex-direction: column;
      width: 100%;
      align-items: flex-start;
    }
  }
</style>
