---
import { config } from '../config';
import AppleIcon from './AppleIcon.astro';
---

<section class="docs-cta-section">
  <div class="pane">
    <div class="pane-header">
      <div class="pane-dots">
        <span class="pane-dot"></span>
        <span class="pane-dot"></span>
        <span class="pane-dot"></span>
      </div>
      <span class="pane-path">~/ready</span>
    </div>
    <div class="cta-body">
      <div class="cta-prompt"><span class="cta-p">$</span> molt --ready<span class="caret"></span></div>
      <h2 class="cta-title">Ready to try it yourself?</h2>
      <p class="cta-sub">Free forever. Uses your existing API keys. Runs locally on your machine.</p>

      <div class="cta-actions" data-download-cta>
        <a href={config.downloadUrl} data-track-download data-dl="mac-arm" class="btn btn-primary">
          <AppleIcon size={16} />
          download.mac
        </a>
        <a href={config.appStoreUrl} data-dl="ios" class="btn btn-primary">
          <AppleIcon size={16} />
          download.ios
        </a>
        <div class="cta-more">
          <button type="button" class="btn" data-dl-toggle>
            all.platforms
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <div class="cta-dropdown" data-dl-dropdown>
            <a href={config.downloadUrl} data-track-download class="cta-dl-item">
              <AppleIcon size={14} />
              macos.apple-silicon
            </a>
            <a href={config.appStoreUrl} class="cta-dl-item">
              <AppleIcon size={14} />
              ios.app-store
            </a>
          </div>
        </div>
      </div>

      <ul class="cta-trust">
        <li>free forever</li>
        <li>no account required</li>
        <li>uses your existing API keys</li>
        <li>macOS, iPhone & iPad</li>
      </ul>
    </div>
  </div>
</section>

<style>
  .docs-cta-section {
    margin-top: 3rem;
  }

  .cta-body {
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
  }

  @media (min-width: 640px) {
    .cta-body {
      padding: 3rem 2.5rem;
    }
  }

  .cta-prompt {
    font-family: var(--font-family-mono);
    font-size: 12px;
    color: var(--color-secondary);
  }

  .cta-p {
    color: var(--color-accent);
    margin-right: 0.25rem;
  }

  .cta-title {
    font-family: var(--font-family-sans);
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-weight: 600;
    color: var(--color-primary);
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin: 0;
    max-width: 32rem;
  }

  .cta-sub {
    font-family: var(--font-family-mono);
    font-size: 13px;
    color: var(--color-secondary);
    line-height: 1.7;
    margin: 0;
    max-width: 32rem;
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.5rem;
    position: relative;
  }

  [data-dl] {
    display: none;
  }

  :global([data-platform="mac-arm"]) [data-dl="mac-arm"],
  :global([data-platform="ios"]) [data-dl="ios"] {
    display: inline-flex;
  }

  .cta-more {
    position: relative;
  }

  .cta-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 0.375rem);
    left: 0;
    flex-direction: column;
    min-width: 14rem;
    padding: 0.25rem;
    border-radius: 8px;
    background: var(--color-surface);
    border: 1px solid var(--color-border-strong);
    z-index: 50;
  }

  .cta-dropdown:global(.open) {
    display: flex;
  }

  .cta-dl-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.625rem;
    border-radius: 6px;
    font-family: var(--font-family-mono);
    font-size: 12px;
    color: var(--color-primary);
    transition: background 120ms ease, color 120ms ease;
  }

  .cta-dl-item:hover {
    background: var(--color-bg);
    color: var(--color-accent);
  }

  .cta-trust {
    list-style: none;
    padding: 1rem 0 0;
    margin: 0.5rem 0 0;
    border-top: 1px dashed var(--color-border);
    width: 100%;
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    font-family: var(--font-family-mono);
    font-size: 11px;
    color: var(--color-muted);
  }

  .cta-trust li::before {
    content: "✓ ";
    color: var(--color-accent);
  }
</style>
