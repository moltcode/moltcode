---
import ThemeToggle from './ThemeToggle.astro';
---

<nav class="nav">
  <div class="nav-inner">
    <a href="/" class="nav-brand">
      <span class="nav-prompt">$</span>
      <span class="nav-name">moltcode</span>
    </a>

    <div class="nav-links">
      <ThemeToggle />
      <a href="/pricing/" class="nav-link">pricing</a>
      <a href="/docs/what-is-moltcode/" class="nav-link">docs</a>
      <a href="https://platform.moltcode.com" class="nav-link nav-link-accent">sign-in</a>
    </div>
  </div>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg);
  }

  .nav-inner {
    max-width: 64rem;
    margin: 0 auto;
    padding: 0.75rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .nav-inner {
      padding: 0.75rem 2rem;
    }
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-family-mono);
    font-size: 13px;
    font-weight: 500;
    color: var(--color-primary);
  }

  .nav-prompt {
    color: var(--color-accent);
  }

  .nav-name {
    letter-spacing: -0.01em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-link {
    padding: 0.375rem 0.625rem;
    font-family: var(--font-family-mono);
    font-size: 12px;
    color: var(--color-secondary);
    border-radius: 4px;
    transition: color 120ms ease, background 120ms ease;
  }

  .nav-link:hover {
    color: var(--color-accent);
  }

  .nav-link-accent {
    color: var(--color-primary);
    border: 1px solid var(--color-border-strong);
  }

  .nav-link-accent:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  @media (max-width: 540px) {
    .nav-link:not(.nav-link-accent):not(.theme-toggle) {
      display: none;
    }
  }
</style>
