---
import ThemeToggle from './ThemeToggle.astro';
import { config } from '../config';
---

<nav class="fixed top-0 left-0 right-0 z-50 glass">
  <div class="max-w-7xl mx-auto px-6 py-3.5">
    <div class="flex items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 group">
        <svg width="32" height="32" viewBox="0 0 64 64" class="rounded-lg shadow-lg group-hover:shadow-[0_0_20px_rgba(231,159,116,0.3)] transition-shadow">
          <defs>
            <linearGradient id="navBgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#27272a"/>
              <stop offset="100%" stop-color="#3f3f46"/>
            </linearGradient>
            <linearGradient id="navCopperGrad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#b45309"/>
              <stop offset="50%" stop-color="#d97706"/>
              <stop offset="100%" stop-color="#92400e"/>
            </linearGradient>
            <linearGradient id="navBronzeGrad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#f59e0b"/>
              <stop offset="100%" stop-color="#d97706"/>
            </linearGradient>
          </defs>
          <rect x="0" y="0" width="64" height="64" rx="14" fill="url(#navBgGrad)"/>
          <rect x="12" y="30" width="16" height="24" rx="4" fill="url(#navCopperGrad)"/>
          <rect x="34" y="20" width="16" height="34" rx="4" fill="url(#navCopperGrad)" opacity="0.7"/>
          <rect x="24" y="10" width="16" height="28" rx="4" fill="url(#navBronzeGrad)"/>
        </svg>
        <span class="text-lg font-semibold text-theme-primary">Molt Code</span>
      </a>

      <!-- Center nav links -->
      <div class="hidden md:flex items-center gap-1 bg-theme-surface/50 rounded-full px-1 py-1 border border-theme-border">
        <a href="#pipeline" class="nav-pill">Pipeline</a>
        <a href="#features" class="nav-pill">Features</a>
        <a href="#agents" class="nav-pill">Agents</a>
        <a href="/docs/what-is-moltcode" class="nav-pill">Docs</a>
        <a href="/docs/changelog" class="nav-pill">Changelog</a>
      </div>

      <!-- Right side -->
      <div class="flex items-center gap-3">
        <ThemeToggle />
        <a href="https://platform.moltcode.com" class="text-theme-secondary hover:text-theme-accent transition-colors text-sm font-medium px-3 py-2">
          Sign in
        </a>
        <a href={config.downloadUrl} data-track-download class="btn-primary px-4 py-2 rounded-full text-sm font-medium">
          Download
        </a>
      </div>
    </div>
  </div>
</nav>

<style>
  .nav-pill {
    padding: 0.375rem 0.875rem;
    border-radius: 9999px;
    font-size: 0.8125rem;
    color: var(--color-secondary);
    transition: all 0.2s ease;
  }

  .nav-pill:hover {
    color: var(--color-accent);
    background: rgba(var(--color-accent-rgb), 0.08);
  }
</style>
