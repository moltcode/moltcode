---
import { config } from '../config';
import AppleIcon from './AppleIcon.astro';
---

<section class="hero" id="hero">
  <div class="hero-inner">
    <!-- Status chips -->
    <div class="hero-chips">
      <span class="chip chip-accent">v0.0.54</span>
      <span class="chip">free.forever</span>
      <span class="chip">your.keys</span>
    </div>

    <!-- Headline -->
    <h1 class="hero-headline">
      One workspace.<br/>
      Any agent.<br/>
      Your keys.<span class="caret"></span>
    </h1>

    <!-- Description -->
    <p class="hero-desc">
      Desktop, iPad, and phone — connected into one mesh. Run any coding agent across all your machines with full context, managed processes, and zero configuration.
    </p>

    <!-- CTAs -->
    <div class="hero-ctas" data-download-cta>
      <a href={config.downloadUrl} data-track-download data-dl="mac-arm" class="btn btn-primary">
        <AppleIcon size={16} />
        download.mac
      </a>
      <a href={config.appStoreUrl} data-dl="ios" class="btn btn-primary">
        <AppleIcon size={16} />
        download.ios
      </a>
      <div class="hero-dl-more">
        <button type="button" class="btn" data-dl-toggle>
          all.platforms
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </button>
        <div class="hero-dl-dropdown" data-dl-dropdown>
          <a href={config.downloadUrl} data-track-download class="hero-dl-item">
            <AppleIcon size={14} />
            macos.apple-silicon
          </a>
          <a href={config.appStoreUrl} class="hero-dl-item">
            <AppleIcon size={14} />
            ios.app-store
          </a>
        </div>
      </div>
    </div>

    <!-- Output line -->
    <div class="hero-output">
      <span class="hero-output-key">→</span> runs your CLIs with your subscriptions, no hack.
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 6rem 1.25rem 3rem;
    display: flex;
    justify-content: center;
  }

  @media (min-width: 640px) {
    .hero {
      padding: 8rem 2rem 4rem;
    }
  }

  .hero-inner {
    width: 100%;
    max-width: 38rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
  }

  .hero-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .hero-headline {
    font-family: var(--font-family-sans);
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-primary);
    margin: 0;
  }

  .hero-desc {
    font-family: var(--font-family-mono);
    font-size: 13px;
    line-height: 1.7;
    color: var(--color-secondary);
    max-width: 32rem;
    margin: 0;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    position: relative;
    margin-top: 0.5rem;
  }

  /* Platform-based primary button visibility */
  [data-dl] {
    display: none;
  }

  :global([data-platform="mac-arm"]) [data-dl="mac-arm"],
  :global([data-platform="ios"]) [data-dl="ios"] {
    display: inline-flex;
  }

  .hero-dl-more {
    position: relative;
  }

  .hero-dl-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 0.375rem);
    left: 0;
    flex-direction: column;
    min-width: 14rem;
    padding: 0.25rem;
    border-radius: 8px;
    background: var(--color-surface);
    border: 1px solid var(--color-border-strong);
    z-index: 50;
  }

  .hero-dl-dropdown:global(.open) {
    display: flex;
  }

  .hero-dl-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.625rem;
    border-radius: 6px;
    font-family: var(--font-family-mono);
    font-size: 12px;
    color: var(--color-primary);
    transition: background 120ms ease, color 120ms ease;
  }

  .hero-dl-item:hover {
    background: var(--color-bg);
    color: var(--color-accent);
  }

  .hero-output {
    font-family: var(--font-family-mono);
    font-size: 12px;
    color: var(--color-muted);
    padding-top: 0.5rem;
    border-top: 1px dashed var(--color-border);
    width: 100%;
    margin-top: 0.5rem;
  }

  .hero-output-key {
    color: var(--color-accent);
    margin-right: 0.375rem;
  }
</style>
