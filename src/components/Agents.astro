---
const agents = [
  { name: 'claude code', provider: 'anthropic', cmd: 'claude' },
  { name: 'codex', provider: 'openai', cmd: 'codex' },
  { name: 'gemini cli', provider: 'google', cmd: 'gemini' },
  { name: 'copilot cli', provider: 'github', cmd: 'copilot' },
  { name: 'pi cli', provider: 'inflection', cmd: 'pi' },
  { name: 'opencode', provider: 'community', cmd: 'opencode' },
];
---

<section class="section">
  <div class="section-head">
    <span class="chip">// runtimes</span>
    <h2 class="section-title">One harness, any engine.</h2>
    <p class="section-sub">Assign Claude to planning, Codex to implementation, Gemini to review. The harness doesn't care who's thinking — just where they're working.</p>
  </div>

  <div class="pane">
    <div class="pane-header">
      <div class="pane-dots">
        <span class="pane-dot"></span>
        <span class="pane-dot"></span>
        <span class="pane-dot"></span>
      </div>
      <span class="pane-path">~/agents/registry</span>
    </div>
    <div class="agents-grid">
      {agents.map((a) => (
        <div class="agent-row">
          <span class="agent-cmd">$ {a.cmd}</span>
          <span class="agent-name">{a.name}</span>
          <span class="agent-prov">{a.provider}</span>
          <span class="agent-status">ready</span>
        </div>
      ))}
    </div>
    <div class="agents-foot">// more runtimes coming — extensible adapter system</div>
  </div>
</section>

<style>
  .section-head {
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.875rem;
  }

  .section-title {
    font-family: var(--font-family-sans);
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin: 0;
  }

  .section-sub {
    font-family: var(--font-family-mono);
    font-size: 13px;
    color: var(--color-secondary);
    line-height: 1.7;
    margin: 0;
    max-width: 36rem;
  }

  .agents-grid {
    display: flex;
    flex-direction: column;
  }

  .agent-row {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    gap: 1rem;
    align-items: center;
    padding: 0.875rem 1.5rem;
    font-family: var(--font-family-mono);
    font-size: 12px;
    border-bottom: 1px solid var(--color-border);
    transition: background 120ms ease;
  }

  @media (min-width: 640px) {
    .agent-row {
      padding: 0.875rem 2rem;
    }
  }

  .agent-row:hover {
    background: var(--color-bg);
  }

  .agent-cmd {
    color: var(--color-accent);
  }

  .agent-name {
    color: var(--color-primary);
    font-weight: 500;
  }

  .agent-prov {
    color: var(--color-muted);
  }

  .agent-status {
    color: #6FB87E;
    font-size: 11px;
  }

  .agent-status::before {
    content: "● ";
  }

  .agents-foot {
    padding: 0.875rem 1.5rem;
    font-family: var(--font-family-mono);
    font-size: 11px;
    color: var(--color-muted);
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
  }

  @media (min-width: 640px) {
    .agents-foot {
      padding: 0.875rem 2rem;
    }
  }
</style>
