---
const features = [
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><path d="M12 18h.01"/></svg>`,
    title: "All your devices. One mesh.",
    description: "Desktop, iPad, and phone — connected. Approve agent work from your phone while you're away.",
    tag: "$9.99/mo",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
    title: "Any provider. Any CLI.",
    description: "Claude, Codex, Gemini, OpenCode, Cursor, Copilot — bring whatever you already use.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
    title: "Agents on the edge.",
    description: "Run agents on Mesh-connected edge nodes. Prompt them all — connection headaches handled.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>`,
    title: "Ship features, not files.",
    description: "Worktrees across multiple projects, organized. Think in features and outcomes.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>`,
    title: "Batteries loaded.",
    description: "Git, search, file tagging, terminal, image annotation — everything agents need.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>`,
    title: "Managed processes.",
    description: "Run dev servers, builds, tests — agents see logs in real-time. No piping.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`,
    title: "PRDs and docs built in.",
    description: "Draft product specs, break down large problems, and let agents resolve them.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>`,
    title: "Issues and epics.",
    description: "Dependency-aware execution chains. Agents resolve them in the exact right order.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
    title: "One interface.",
    description: "Files, git, issues, agents, processes, docs — no more switching between five tools.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
    title: "Managed MCPs.",
    description: "Model Context Protocol servers run in the app. Agents get tool access. Zero config.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>`,
    title: "Managed LSPs.",
    description: "Language servers in the app. Full type info, go-to-definition, and diagnostics for agents.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    title: "Don't let agents wait.",
    description: "Approve from your phone while you're away. Agents keep shipping — even from the couch.",
  },
];
---

<section class="features-section" id="features">
  <div class="features-inner">
    <div class="features-header">
      <span class="features-eyebrow">Everything included</span>
      <h2 class="features-title">Built for how agents actually work.</h2>
      <p class="features-subtitle">One app. Every tool your agents need. No configuration required.</p>
    </div>

    <div class="features-grid">
      {features.map((feature) => (
        <div class="feature-card">
          <div class="feature-icon" set:html={feature.icon} />
          <div class="feature-text">
            <div class="feature-name-row">
              <h3 class="feature-name">{feature.title}</h3>
              {feature.tag && <span class="feature-tag">{feature.tag}</span>}
            </div>
            <p class="feature-desc">{feature.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features-section {
    position: relative;
    padding: 6rem 1.5rem 8rem;
  }

  @media (min-width: 640px) {
    .features-section {
      padding: 8rem 2rem 10rem;
    }
  }

  .features-inner {
    max-width: 76rem;
    margin: 0 auto;
  }

  /* Header */
  .features-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  @media (min-width: 640px) {
    .features-header {
      margin-bottom: 4rem;
    }
  }

  .features-eyebrow {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-accent);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .features-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    color: var(--color-primary);
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
    line-height: 1.15;
  }

  .features-subtitle {
    font-size: 1.0625rem;
    color: var(--color-secondary);
    max-width: 28rem;
    margin: 0 auto;
    line-height: 1.5;
  }

  /* Grid — border table style */
  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--color-border);
    border-radius: 1rem;
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  @media (min-width: 640px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1280px) {
    .features-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* Card */
  .feature-card {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
    padding: 1.5rem;
    background: var(--color-bg);
    transition: background 0.25s ease;
  }

  .feature-card:hover {
    background: var(--color-surface);
  }

  @media (min-width: 640px) {
    .feature-card {
      padding: 1.75rem;
    }
  }

  /* Icon */
  .feature-icon {
    width: 2.5rem;
    height: 2.5rem;
    min-width: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.625rem;
    background: rgba(var(--color-accent-rgb), 0.08);
    color: var(--color-accent);
    flex-shrink: 0;
  }

  /* Text */
  .feature-text {
    min-width: 0;
  }

  .feature-name-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
    flex-wrap: wrap;
  }

  .feature-name {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-primary);
    line-height: 1.3;
  }

  .feature-tag {
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--color-accent);
    background: rgba(var(--color-accent-rgb), 0.1);
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    white-space: nowrap;
  }

  .feature-desc {
    font-size: 0.8125rem;
    color: var(--color-secondary);
    line-height: 1.55;
  }
</style>
