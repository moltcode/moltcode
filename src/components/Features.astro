---
const features = [
  ['providers', 'Any provider. Any CLI.', 'Claude, Codex, Gemini, OpenCode, Cursor, Copilot — bring whatever you already use.'],
  ['edge', 'Agents on the edge.', 'Run agents on Mesh-connected edge nodes. Prompt them all — connection headaches handled.'],
  ['features', 'Ship features, not files.', 'Worktrees across multiple projects, organized. Think in features and outcomes.'],
  ['batteries', 'Batteries loaded.', 'Git, search, file tagging, terminal, image annotation — everything agents need.'],
  ['processes', 'Managed processes.', 'Run dev servers, builds, tests — agents see logs in real-time. No piping.'],
  ['prds', 'PRDs and docs built in.', 'Draft product specs, break down large problems, and let agents resolve them.'],
  ['issues', 'Issues and epics.', 'Dependency-aware execution chains. Agents resolve them in the exact right order.'],
  ['interface', 'One interface.', 'Files, git, issues, agents, processes, docs — no more switching between five tools.'],
  ['mcp', 'Managed MCPs.', 'Model Context Protocol servers run in the app. Agents get tool access. Zero config.'],
  ['lsp', 'Managed LSPs.', 'Language servers in the app. Full type info, go-to-definition, and diagnostics for agents.'],
];
---

<section class="section" id="features">
  <div class="section-head">
    <span class="chip">// everything.included</span>
    <h2 class="section-title">Built for you to leave that beefy machine at home.</h2>
    <p class="section-sub">One app. Every tool your agents need. No configuration required.</p>
  </div>

  <!-- Hero feature pane -->
  <div class="pane mesh-pane">
    <div class="pane-header">
      <div class="pane-dots">
        <span class="pane-dot"></span>
        <span class="pane-dot"></span>
        <span class="pane-dot"></span>
      </div>
      <span class="pane-path">~/mesh/devices</span>
    </div>
    <div class="mesh-body">
      <h3 class="mesh-title">All your devices. One mesh.</h3>
      <p class="mesh-desc">Your desktop runs the agents. Your phone approves their work. Your iPad reviews the diffs. Connected into a single mesh — no forwarding, no VPN, no SSH tunnels. Just your machines, working together.</p>
      <div class="mesh-chips">
        <span class="chip chip-accent">desktop</span>
        <span class="chip chip-accent">phone</span>
        <span class="chip chip-accent">ipad</span>
      </div>
    </div>
  </div>

  <!-- Feature grid -->
  <div class="feat-grid">
    {features.map(([tag, title, desc]) => (
      <div class="feat-row">
        <span class="feat-tag">[{tag}]</span>
        <div class="feat-text">
          <span class="feat-title">{title}</span>
          <span class="feat-desc">{desc}</span>
        </div>
      </div>
    ))}
  </div>

  <p class="feat-belief">› Every machine you own should be useful.</p>
</section>

<style>
  .section-head {
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.875rem;
  }

  .section-title {
    font-family: var(--font-family-sans);
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin: 0;
  }

  .section-sub {
    font-family: var(--font-family-mono);
    font-size: 13px;
    color: var(--color-secondary);
    line-height: 1.7;
    margin: 0;
    max-width: 36rem;
  }

  .mesh-pane {
    margin-bottom: 1.5rem;
  }

  .mesh-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  @media (min-width: 640px) {
    .mesh-body {
      padding: 2rem;
    }
  }

  .mesh-title {
    font-family: var(--font-family-sans);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-primary);
    margin: 0;
    letter-spacing: -0.01em;
  }

  .mesh-desc {
    font-family: var(--font-family-mono);
    font-size: 13px;
    color: var(--color-secondary);
    line-height: 1.7;
    margin: 0;
  }

  .mesh-chips {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 0.25rem;
  }

  .feat-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    background: var(--color-surface);
  }

  @media (min-width: 768px) {
    .feat-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .feat-row {
    display: flex;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--color-border);
    font-family: var(--font-family-mono);
    font-size: 12px;
    transition: background 120ms ease;
  }

  .feat-row:hover {
    background: var(--color-bg);
  }

  @media (min-width: 768px) {
    .feat-row:nth-child(odd) {
      border-right: 1px solid var(--color-border);
    }
    .feat-row:nth-last-child(-n+2) {
      border-bottom: none;
    }
  }

  @media (max-width: 767px) {
    .feat-row:last-child {
      border-bottom: none;
    }
  }

  .feat-tag {
    color: var(--color-accent);
    flex-shrink: 0;
    width: 6.5rem;
    font-size: 11px;
  }

  .feat-text {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }

  .feat-title {
    color: var(--color-primary);
    font-weight: 500;
  }

  .feat-desc {
    color: var(--color-secondary);
    line-height: 1.6;
    font-size: 11.5px;
  }

  .feat-belief {
    margin-top: 1.5rem;
    font-family: var(--font-family-mono);
    font-size: 13px;
    color: var(--color-accent);
    text-align: center;
  }
</style>
