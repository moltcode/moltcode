---
import { config } from '../config';
import AppleIcon from './AppleIcon.astro';
---

<section class="py-28 px-6 relative overflow-hidden">
  <!-- Animated background -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[900px] h-[450px] rounded-full blur-[150px]" style="background: rgba(var(--color-accent-rgb), 0.08)"></div>
    <div class="cta-grid-bg"></div>
  </div>

  <div class="max-w-3xl mx-auto text-center relative z-10">
    <!-- Decorative bracket -->
    <div class="cta-bracket">
      <span class="bracket-char">{</span>
      <span class="bracket-text">ready?</span>
      <span class="bracket-char">}</span>
    </div>

    <h2 class="text-3xl md:text-5xl font-bold text-theme-primary mb-4 leading-tight">
      Give your agents<br />
      <span class="gradient-text">the harness they deserve.</span>
    </h2>
    <p class="text-lg text-theme-primary/50 mb-10 max-w-xl mx-auto">
      Structure, context, and coordination for agents working across your workspaces. Free forever.
    </p>
    <div class="cta-dl-wrap" data-download-cta>
      <a href={config.downloadUrl} data-track-download data-dl="mac-arm" class="cta-button-primary">
        <AppleIcon size={20} />
        <span>Download for Mac (Apple Silicon)</span>
      </a>
      <a href={config.appStoreUrl} data-dl="ios" class="cta-button-primary">
        <AppleIcon size={20} />
        <span>Get on iPhone & iPad</span>
      </a>
      <div class="cta-dl-more">
        <button type="button" class="cta-dl-toggle" data-dl-toggle>
          All downloads
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </button>
        <div class="cta-dl-dropdown" data-dl-dropdown>
          <a href={config.downloadUrl} data-track-download class="cta-dl-item">
            <AppleIcon size={16} />
            macOS — Apple Silicon
          </a>
          <a href={config.appStoreUrl} class="cta-dl-item">
            <AppleIcon size={16} />
            iPhone & iPad — App Store
          </a>
        </div>
      </div>
    </div>

    <!-- Trust signals -->
    <div class="trust-signals">
      <span class="trust-item">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
        Free forever
      </span>
      <span class="trust-item">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
        No account required
      </span>
      <span class="trust-item">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
        Uses your existing API keys
      </span>
      <span class="trust-item">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
        macOS, iPhone &amp; iPad
      </span>
    </div>
  </div>
</section>

<style>
  .cta-grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(var(--color-accent-rgb), 0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(var(--color-accent-rgb), 0.02) 1px, transparent 1px);
    background-size: 50px 50px;
    mask-image: radial-gradient(ellipse 50% 60% at 50% 50%, black, transparent);
    -webkit-mask-image: radial-gradient(ellipse 50% 60% at 50% 50%, black, transparent);
  }

  .cta-bracket {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    font-family: var(--font-family-mono);
  }

  .bracket-char {
    font-size: 1.5rem;
    font-weight: 300;
    color: var(--color-accent);
    opacity: 0.4;
  }

  .bracket-text {
    font-size: 0.875rem;
    color: var(--color-accent);
    opacity: 0.6;
    letter-spacing: 0.05em;
  }

  .cta-button-primary {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    border-radius: 9999px;
    font-size: 1.0625rem;
    font-weight: 600;
    color: white;
    background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-strong) 100%);
    box-shadow:
      0 0 0 1px rgba(var(--color-accent-rgb), 0.3),
      0 8px 24px rgba(var(--color-accent-rgb), 0.25),
      inset 0 1px 0 rgba(255,255,255,0.15);
    transition: all 0.3s ease;
    min-width: 12rem;
  }

  .cta-button-primary:hover,
  .cta-button-secondary:hover {
    transform: translateY(-2px);
    box-shadow:
      0 0 0 1px rgba(var(--color-accent-rgb), 0.4),
      0 12px 32px rgba(var(--color-accent-rgb), 0.35),
      inset 0 1px 0 rgba(255,255,255,0.15);
  }

  .cta-dl-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  /* Platform-based primary button visibility */
  [data-dl] {
    display: none;
  }

  :global([data-platform="mac-arm"]) [data-dl="mac-arm"],
  :global([data-platform="ios"]) [data-dl="ios"] {
    display: flex;
  }

  .cta-dl-more {
    position: relative;
  }

  .cta-dl-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0;
    border: none;
    background: none;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-secondary);
    cursor: pointer;
    transition: color 0.2s ease;
    font-family: inherit;
  }

  .cta-dl-toggle:hover {
    color: var(--text-primary);
  }

  .cta-dl-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 50%;
    transform: translateX(-50%);
    flex-direction: column;
    min-width: 14rem;
    padding: 0.375rem;
    border-radius: 0.75rem;
    background: var(--color-surface-solid);
    border: 1px solid var(--color-border);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
    z-index: 999;
  }

  .cta-dl-dropdown:global(.open) {
    display: flex;
  }

  .cta-dl-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    border-radius: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-primary);
    text-decoration: none;
    transition: background 0.15s ease;
    white-space: nowrap;
  }

  .cta-dl-item:hover {
    background: rgba(var(--color-accent-rgb), 0.08);
  }

  .trust-signals {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 1rem 1.5rem;
    margin-top: 2rem;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    color: var(--color-secondary);
    opacity: 0.5;
  }

  .trust-item svg {
    color: #28c840;
    opacity: 0.7;
  }
</style>
