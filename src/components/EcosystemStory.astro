---
const devices = [
  {
    path: '~/devices/desktop',
    label: 'desktop.app',
    title: 'Where the thinking happens.',
    desc: 'Your beefy machine at home or the office. Full IDE, managed processes, agents running across every workspace. This is the engine room.',
    img: '/app.png',
  },
  {
    path: '~/devices/ipad',
    label: 'ipad.app',
    title: 'Take the whole picture with you.',
    desc: 'At a cafe, in a meeting, on the couch. Pull up diffs, review agent work, walk someone through the architecture.',
    img: '/ipad.png',
  },
  {
    path: '~/devices/phone',
    label: 'iphone.app',
    title: 'Step away. Stay in the loop.',
    desc: "Go for a walk. Grab dinner. Your agents keep working. Glance at your phone to see what shipped, what needs approval, and what's next.",
    img: '/phone.png',
  },
];
---

<section class="section" id="ecosystem">
  <div class="section-head">
    <span class="chip">// the.ecosystem</span>
    <h2 class="section-title">Three devices. One system. Every moment covered.</h2>
  </div>

  <div class="eco-stack">
    {devices.map((d) => (
      <div class="pane eco-pane">
        <div class="pane-header">
          <div class="pane-dots">
            <span class="pane-dot"></span>
            <span class="pane-dot"></span>
            <span class="pane-dot"></span>
          </div>
          <span class="pane-path">{d.path}</span>
        </div>
        <div class="eco-body">
          <div class="eco-copy">
            <span class="chip chip-accent">{d.label}</span>
            <h3 class="eco-title">{d.title}</h3>
            <p class="eco-desc">{d.desc}</p>
          </div>
          <div class="eco-img-wrap">
            <img src={d.img} alt={d.title} loading="lazy" />
          </div>
        </div>
      </div>
    ))}

    <!-- Headless pane -->
    <div class="pane eco-pane">
      <div class="pane-header">
        <div class="pane-dots">
          <span class="pane-dot"></span>
          <span class="pane-dot"></span>
          <span class="pane-dot"></span>
        </div>
        <span class="pane-path">moltcode --headless</span>
      </div>
      <div class="eco-body">
        <div class="eco-copy">
          <span class="chip">coming.soon</span>
          <h3 class="eco-title">No screen. Pure horsepower.</h3>
          <p class="eco-desc">Deploy Molt Code headless on any server. CI runners, cloud VMs, bare metal — agents work your codebases without a GUI. Same mesh, same control from your phone.</p>
        </div>
        <div class="eco-term">
          <div class="t-line"><span class="t-prompt">$</span> moltcode serve --headless</div>
          <div class="t-line t-dim">&nbsp;</div>
          <div class="t-line t-accent">  molt code v0.1.0 — headless mode</div>
          <div class="t-line t-dim">  Listening on mesh...</div>
          <div class="t-line t-dim">&nbsp;</div>
          <div class="t-line"><span class="t-ok">●</span> workspace <span class="t-accent">api-server</span> connected</div>
          <div class="t-line"><span class="t-ok">●</span> workspace <span class="t-accent">ml-pipeline</span> connected</div>
          <div class="t-line"><span class="t-ok">●</span> workspace <span class="t-accent">infra</span> connected</div>
          <div class="t-line t-dim">&nbsp;</div>
          <div class="t-line"><span class="t-arrow">→</span> agent <span class="t-accent">claude</span> resolving <span class="t-dim">ISS-042</span></div>
          <div class="t-line"><span class="t-arrow">→</span> agent <span class="t-accent">codex</span> running tests on <span class="t-dim">ml-pipeline</span></div>
          <div class="t-line"><span class="t-ok">✓</span> agent <span class="t-accent">claude</span> pushed <span class="t-dim">fix/auth-middleware</span></div>
          <div class="t-line t-dim">&nbsp;</div>
          <div class="t-line t-dim">  3 workspaces · 2 agents active · uptime 4d 11h</div>
          <div class="t-line"><span class="caret"></span></div>
        </div>
      </div>
    </div>

    <!-- Subscribe pane -->
    <a href="https://platform.moltcode.com" class="pane eco-cta-pane">
      <div class="pane-header">
        <div class="pane-dots">
          <span class="pane-dot"></span>
          <span class="pane-dot"></span>
          <span class="pane-dot"></span>
        </div>
        <span class="pane-path">~/subscribe</span>
      </div>
      <div class="eco-cta-body">
        <div class="eco-cta-row">
          <div>
            <div class="eco-cta-label">One mesh. Every device.</div>
            <div class="eco-cta-sub">Desktop, iPad & iPhone — connected and in sync.</div>
          </div>
          <div class="eco-cta-right">
            <span class="eco-cta-price"><span class="eco-cta-amount">$9.99</span>/mo</span>
            <span class="eco-cta-action">subscribe →</span>
          </div>
        </div>
        <ul class="eco-cta-checks">
          <li>connect up to 5 devices</li>
          <li>access any runner from phone and iPad</li>
          <li>resilient traffic routing</li>
        </ul>
      </div>
    </a>
  </div>
</section>

<style>
  .section-head {
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.875rem;
  }

  .section-title {
    font-family: var(--font-family-sans);
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin: 0;
  }

  .eco-stack {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .eco-body {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    padding: 1.5rem;
  }

  @media (min-width: 768px) {
    .eco-body {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
      padding: 2rem;
    }
  }

  .eco-copy {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: flex-start;
  }

  .eco-title {
    font-family: var(--font-family-sans);
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-primary);
    margin: 0;
  }

  .eco-desc {
    font-family: var(--font-family-mono);
    font-size: 12px;
    color: var(--color-secondary);
    line-height: 1.7;
    margin: 0;
  }

  .eco-img-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 0.75rem;
  }

  .eco-img-wrap img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 4px;
  }

  /* Terminal block */
  .eco-term {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 1rem;
    font-family: var(--font-family-mono);
    font-size: 11px;
    line-height: 1.7;
    color: var(--color-secondary);
    overflow: hidden;
  }

  .t-line {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .t-prompt { color: var(--color-accent); margin-right: 0.375rem; }
  .t-dim { color: var(--color-muted); }
  .t-accent { color: var(--color-accent); }
  .t-ok { color: #6FB87E; }
  .t-arrow { color: #5A9FD4; }

  /* Subscribe CTA pane */
  .eco-cta-pane {
    text-decoration: none;
  }

  .eco-cta-body {
    padding: 1.5rem;
  }

  @media (min-width: 640px) {
    .eco-cta-body {
      padding: 2rem;
    }
  }

  .eco-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 1rem;
    border-bottom: 1px dashed var(--color-border);
    margin-bottom: 1rem;
  }

  .eco-cta-label {
    font-family: var(--font-family-sans);
    font-size: 14px;
    font-weight: 600;
    color: var(--color-primary);
  }

  .eco-cta-sub {
    font-family: var(--font-family-mono);
    font-size: 12px;
    color: var(--color-secondary);
    margin-top: 0.25rem;
  }

  .eco-cta-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.25rem;
  }

  .eco-cta-price {
    font-family: var(--font-family-mono);
    font-size: 12px;
    color: var(--color-secondary);
  }

  .eco-cta-amount {
    font-family: var(--font-family-sans);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-accent);
  }

  .eco-cta-action {
    font-family: var(--font-family-mono);
    font-size: 12px;
    color: var(--color-accent);
    transition: letter-spacing 120ms ease;
  }

  .eco-cta-pane:hover .eco-cta-action {
    letter-spacing: 0.04em;
  }

  .eco-cta-checks {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .eco-cta-checks li {
    font-family: var(--font-family-mono);
    font-size: 12px;
    color: var(--color-secondary);
    padding-left: 1.25rem;
    position: relative;
  }

  .eco-cta-checks li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--color-accent);
  }
</style>
