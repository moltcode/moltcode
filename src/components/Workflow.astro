---
const capabilities = [
  { tag: 'review', cmd: 'molt diff', title: 'Review diffs, not guesses.', desc: 'Side-by-side diffs for every change agents make. Inline comments, threaded discussions, file-by-file navigation. You stay in control of what ships.' },
  { tag: 'git', cmd: 'molt git status', title: 'Git that works for you.', desc: 'Real-time status, staging, diffs, and worktree management. Agents commit with context. You see every change as it happens.' },
  { tag: 'terminal', cmd: 'molt term', title: 'Built-in terminals. No piping.', desc: 'Full PTY terminals inside the app. Agents see output in real-time. Multiple sessions, reconnect on resume, resize on the fly.' },
  { tag: 'processes', cmd: 'molt proc up', title: 'Dev servers that manage themselves.', desc: 'Auto-start processes, monitor health, stream logs. OOM restart policies, port forwarding, and public URL sharing — all from the sidebar.' },
  { tag: 'issues', cmd: 'molt issue', title: 'Track work. Not tickets.', desc: 'Hierarchical issues with dependency-aware execution chains. Create an epic, agents resolve sub-issues in the right order automatically.' },
  { tag: 'permissions', cmd: 'molt perm', title: 'Agents ask before they act.', desc: 'Every sensitive operation goes through approval. Sandbox untrusted sessions. Encrypted secrets vault. MCP permission server built in.' },
];
---

<section class="section" id="workflow">
  <div class="section-head">
    <span class="chip">// developer.workflow</span>
    <h2 class="section-title">Everything agents need. Nothing you need to configure.</h2>
    <p class="section-sub">Code review, git, terminals, process management, issue tracking, and security — built in, not bolted on.</p>
  </div>

  <div class="wf-grid">
    {capabilities.map((c) => (
      <div class="pane wf-pane">
        <div class="pane-header">
          <div class="pane-dots">
            <span class="pane-dot"></span>
            <span class="pane-dot"></span>
            <span class="pane-dot"></span>
          </div>
          <span class="pane-path">~/{c.tag}</span>
        </div>
        <div class="wf-body">
          <div class="wf-cmd"><span class="wf-prompt">$</span> {c.cmd}</div>
          <h3 class="wf-title">{c.title}</h3>
          <p class="wf-desc">{c.desc}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .section-head {
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.875rem;
  }

  .section-title {
    font-family: var(--font-family-sans);
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin: 0;
  }

  .section-sub {
    font-family: var(--font-family-mono);
    font-size: 13px;
    color: var(--color-secondary);
    line-height: 1.7;
    margin: 0;
    max-width: 36rem;
  }

  .wf-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .wf-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 1024px) {
    .wf-grid {
      grid-template-columns: 1fr 1fr 1fr;
    }
  }

  .wf-body {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .wf-cmd {
    font-family: var(--font-family-mono);
    font-size: 11px;
    color: var(--color-muted);
    margin-bottom: 0.25rem;
  }

  .wf-prompt {
    color: var(--color-accent);
    margin-right: 0.25rem;
  }

  .wf-title {
    font-family: var(--font-family-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-primary);
    margin: 0;
    letter-spacing: -0.005em;
  }

  .wf-desc {
    font-family: var(--font-family-mono);
    font-size: 12px;
    color: var(--color-secondary);
    line-height: 1.65;
    margin: 0;
  }
</style>
