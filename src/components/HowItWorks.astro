---
const steps = [
  {
    n: '01',
    cmd: 'molt prd new',
    title: 'Write a PRD',
    desc: 'Describe what you want built — scope, constraints, acceptance criteria. Or let a Planner agent draft it by exploring your codebase.',
    note: 'Structured templates keep specs focused. Agents read them directly.',
  },
  {
    n: '02',
    cmd: 'molt epic generate',
    title: 'Generate an epic',
    desc: 'The system breaks your PRD into dependency-tracked issues, orders them, and bundles them into an execution chain.',
    note: 'Each issue knows its blockers and sequence. No manual breakdown needed.',
  },
  {
    n: '03',
    cmd: 'molt epic resolve',
    title: 'A tree of agents resolves it',
    desc: 'A supervisor agent spawns a tree of coding agents that systematically resolve each issue in dependency order.',
    note: 'You review diffs and approve. Desktop notifications tell you when agents need input.',
  },
];
---

<section class="section">
  <div class="section-head">
    <span class="chip">// the.pipeline</span>
    <h2 class="section-title">From intent to shipped code.</h2>
  </div>

  <div class="steps">
    {steps.map((s) => (
      <div class="pane step-pane">
        <div class="pane-header">
          <div class="pane-dots">
            <span class="pane-dot"></span>
            <span class="pane-dot"></span>
            <span class="pane-dot"></span>
          </div>
          <span class="pane-path">step.{s.n}</span>
        </div>
        <div class="step-body">
          <div class="step-cmd"><span class="step-prompt">$</span> {s.cmd}</div>
          <h3 class="step-title">{s.title}</h3>
          <p class="step-desc">{s.desc}</p>
          <div class="step-note">› {s.note}</div>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .section-head {
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.875rem;
  }

  .section-title {
    font-family: var(--font-family-sans);
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin: 0;
  }

  .steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 768px) {
    .steps {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .step-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .step-cmd {
    font-family: var(--font-family-mono);
    font-size: 12px;
    color: var(--color-secondary);
    margin-bottom: 0.25rem;
  }

  .step-prompt {
    color: var(--color-accent);
    margin-right: 0.25rem;
  }

  .step-title {
    font-family: var(--font-family-sans);
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-primary);
    margin: 0;
    letter-spacing: -0.01em;
  }

  .step-desc {
    font-family: var(--font-family-mono);
    font-size: 12px;
    color: var(--color-secondary);
    line-height: 1.7;
    margin: 0;
  }

  .step-note {
    font-family: var(--font-family-mono);
    font-size: 11px;
    color: var(--color-muted);
    padding-top: 0.625rem;
    margin-top: 0.25rem;
    border-top: 1px dashed var(--color-border);
  }
</style>
