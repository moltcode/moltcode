      <rect x="204" y="140" width="48" height="28" rx="4" fill="rgba(var(--color-accent-rgb), 0.06)" stroke="rgba(var(--color-accent-rgb), 0.2)" stroke-width="1"/>
      <rect x="210" y="146" width="36" height="16" rx="2" fill="rgba(var(--color-accent-rgb), 0.08)"/>
      <circle cx="214" cy="150" r="2" fill="rgba(40, 200, 64, 0.5)"/>
      <line x1="204" y1="154" x2="152" y2="120" stroke="rgba(var(--color-accent-rgb), 0.2)" stroke-width="1" stroke-dasharray="3 3"/>
    </svg>`,
  },
];
---

<section id="platform" class="py-16 md:py-24 px-4 md:px-6 relative">
  <!-- Top accent line -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[1px] bg-gradient-to-r from-transparent via-[rgba(var(--color-accent-rgb),0.15)] to-transparent"></div>

  <div class="max-w-5xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-10 md:mb-16">
      <div class="platform-badge">
        <span class="platform-badge-dot"></span>
        Platform
      </div>
      <h2 class="text-2xl md:text-4xl font-bold text-theme-primary mb-3 md:mb-4">
        One platform.<br /><span class="gradient-text">Every machine.</span>
      </h2>
      <p class="text-sm md:text-base text-theme-primary/50 max-w-2xl mx-auto mb-8">
        Sign in to connect your desktops, phones, cloud instances, and edge devices into a unified fleet for your AI agents.
      </p>
      <a href="https://platform.moltcode.com" class="platform-signin-btn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
          <polyline points="10 17 15 12 10 7"/>
          <line x1="15" y1="12" x2="3" y2="12"/>
        </svg>
        <span>Sign in to Platform</span>
      </a>
    </div>

    <!-- 3-step onboarding -->
    <div class="onboarding-hero">
      <h3 class="text-lg md:text-xl font-semibold text-theme-primary mb-2">Get started in 3 steps</h3>
      <p class="text-sm text-theme-primary/50 mb-8 max-w-md mx-auto">Install on your desktop, grab the mobile app, and manage your infra from anywhere.</p>

      <div class="onboarding-steps">
        <!-- Step 1: Desktop -->
        <div class="onboarding-step">
          <div class="step-number">1</div>
          <div class="step-illustration">
            <svg width="100%" height="100%" viewBox="0 0 160 120" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="10" y="100" width="140" height="4" rx="2" fill="rgba(var(--color-accent-rgb), 0.1)"/>
              <rect x="30" y="16" width="100" height="68" rx="6" fill="rgba(var(--color-accent-rgb), 0.06)" stroke="rgba(var(--color-accent-rgb), 0.3)" stroke-width="1.5"/>
              <rect x="36" y="22" width="88" height="52" rx="3" fill="rgba(var(--color-accent-rgb), 0.1)"/>
              <rect x="42" y="28" width="36" height="3" rx="1.5" fill="rgba(var(--color-accent-rgb), 0.3)"/>
              <rect x="42" y="34" width="56" height="2.5" rx="1" fill="rgba(var(--color-accent-rgb), 0.15)"/>
              <rect x="42" y="39" width="44" height="2.5" rx="1" fill="rgba(var(--color-accent-rgb), 0.15)"/>
              <rect x="42" y="44" width="62" height="2.5" rx="1" fill="rgba(var(--color-accent-rgb), 0.12)"/>
              <rect x="42" y="49" width="38" height="2.5" rx="1" fill="rgba(var(--color-accent-rgb), 0.12)"/>
              <rect x="42" y="55" width="6" height="2.5" rx="1" fill="rgba(var(--color-accent-rgb), 0.5)">
                <animate attributeName="opacity" values="1;0;1" dur="1.2s" repeatCount="indefinite"/>
              </rect>
              <circle cx="108" cy="30" r="3" fill="rgba(40, 200, 64, 0.6)"/>
              <rect x="100" y="56" width="12" height="10" rx="2" fill="rgba(var(--color-accent-rgb), 0.25)"/>
              <rect x="70" y="84" width="20" height="6" rx="1" fill="rgba(var(--color-accent-rgb), 0.15)"/>
              <rect x="60" y="90" width="40" height="4" rx="2" fill="rgba(var(--color-accent-rgb), 0.12)"/>
              <circle cx="80" cy="4" r="8" fill="rgba(var(--color-accent-rgb), 0.12)" stroke="rgba(var(--color-accent-rgb), 0.3)" stroke-width="1">
                <animate attributeName="r" values="8;10;8" dur="2s" repeatCount="indefinite"/>
              </circle>
              <path d="M77 2 L80 6 L83 2" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round" fill="none"/>
              <line x1="80" y1="-1" x2="80" y2="5" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <h4 class="step-title">Install Desktop App</h4>
          <p class="step-desc">Run the agent on your machine. It connects your desktop to the Molt mesh.</p>
        </div>

        <div class="step-connector">
          <svg width="40" height="24" viewBox="0 0 40 24" fill="none">
            <path d="M4 12 L30 12" stroke="rgba(var(--color-accent-rgb), 0.3)" stroke-width="1.5" stroke-dasharray="4 3"/>
            <path d="M26 7 L33 12 L26 17" stroke="rgba(var(--color-accent-rgb), 0.4)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          </svg>
        </div>

        <!-- Step 2: Mobile -->
        <div class="onboarding-step">
          <div class="step-number">2</div>
          <div class="step-illustration">
            <svg width="100%" height="100%" viewBox="0 0 160 120" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="48" y="8" width="64" height="104" rx="12" fill="rgba(var(--color-accent-rgb), 0.05)" stroke="rgba(var(--color-accent-rgb), 0.35)" stroke-width="1.5"/>
              <rect x="66" y="12" width="28" height="6" rx="3" fill="rgba(var(--color-accent-rgb), 0.12)"/>
              <rect x="54" y="22" width="52" height="78" rx="4" fill="rgba(var(--color-accent-rgb), 0.08)"/>
              <rect x="60" y="28" width="28" height="3.5" rx="1.5" fill="rgba(var(--color-accent-rgb), 0.3)"/>
              <rect x="60" y="37" width="40" height="18" rx="3" fill="rgba(var(--color-accent-rgb), 0.06)" stroke="rgba(var(--color-accent-rgb), 0.15)" stroke-width="0.75"/>
              <circle cx="66" cy="43" r="2.5" fill="rgba(40, 200, 64, 0.5)" stroke="rgba(40, 200, 64, 0.6)" stroke-width="0.75"/>
              <rect x="72" y="41" width="22" height="2.5" rx="1" fill="rgba(var(--color-accent-rgb), 0.2)"/>
              <rect x="72" y="47" width="16" height="2" rx="1" fill="rgba(var(--color-accent-rgb), 0.1)"/>
              <rect x="60" y="59" width="40" height="18" rx="3" fill="rgba(var(--color-accent-rgb), 0.06)" stroke="rgba(var(--color-accent-rgb), 0.15)" stroke-width="0.75"/>
              <circle cx="66" cy="65" r="2.5" fill="rgba(40, 200, 64, 0.5)" stroke="rgba(40, 200, 64, 0.6)" stroke-width="0.75"/>
              <rect x="72" y="63" width="18" height="2.5" rx="1" fill="rgba(var(--color-accent-rgb), 0.2)"/>
              <rect x="72" y="69" width="24" height="2" rx="1" fill="rgba(var(--color-accent-rgb), 0.1)"/>
              <rect x="60" y="82" width="40" height="10" rx="5" fill="rgba(var(--color-accent-rgb), 0.2)" stroke="rgba(var(--color-accent-rgb), 0.3)" stroke-width="0.75"/>
              <text x="80" y="89.5" text-anchor="middle" fill="var(--color-accent)" font-size="6" font-family="var(--font-family-mono)" font-weight="600">CONNECT</text>
              <rect x="68" y="104" width="24" height="3" rx="1.5" fill="rgba(var(--color-accent-rgb), 0.15)"/>
              <path d="M118 40 C124 40, 128 36, 128 30" stroke="rgba(var(--color-accent-rgb), 0.15)" stroke-width="1" fill="none"/>
              <path d="M118 48 C130 48, 136 38, 136 28" stroke="rgba(var(--color-accent-rgb), 0.1)" stroke-width="1" fill="none"/>
              <path d="M118 56 C136 56, 144 40, 144 26" stroke="rgba(var(--color-accent-rgb), 0.06)" stroke-width="1" fill="none"/>
            </svg>
          </div>
          <h4 class="step-title">Get the Mobile App</h4>
          <p class="step-desc">Install on your phone. See all your machines, connect, and manage agents on the go.</p>
        </div>

        <div class="step-connector">
          <svg width="40" height="24" viewBox="0 0 40 24" fill="none">
            <path d="M4 12 L30 12" stroke="rgba(var(--color-accent-rgb), 0.3)" stroke-width="1.5" stroke-dasharray="4 3"/>
            <path d="M26 7 L33 12 L26 17" stroke="rgba(var(--color-accent-rgb), 0.4)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          </svg>
        </div>

        <!-- Step 3: Relax -->
        <div class="onboarding-step">
          <div class="step-number">3</div>
          <div class="step-illustration">
            <svg width="100%" height="100%" viewBox="0 0 160 120" fill="none" xmlns="http://www.w3.org/2000/svg">
              <!-- Couch -->
              <path d="M16 72 Q16 48, 40 48 L120 48 Q144 48, 144 72 L144 92 L16 92 Z" fill="rgba(var(--color-accent-rgb), 0.06)" stroke="rgba(var(--color-accent-rgb), 0.15)" stroke-width="1"/>
              <rect x="12" y="82" width="136" height="16" rx="6" fill="rgba(var(--color-accent-rgb), 0.08)" stroke="rgba(var(--color-accent-rgb), 0.2)" stroke-width="1"/>
              <rect x="24" y="98" width="4" height="8" rx="2" fill="rgba(var(--color-accent-rgb), 0.15)"/>
              <rect x="132" y="98" width="4" height="8" rx="2" fill="rgba(var(--color-accent-rgb), 0.15)"/>

              <!-- Person -->
              <circle cx="70" cy="34" r="10" fill="rgba(var(--color-accent-rgb), 0.12)" stroke="rgba(var(--color-accent-rgb), 0.25)" stroke-width="1"/>
              <path d="M60 44 Q58 60, 56 80" stroke="rgba(var(--color-accent-rgb), 0.2)" stroke-width="8" stroke-linecap="round" fill="none"/>
              <path d="M64 52 Q78 56, 88 50" stroke="rgba(var(--color-accent-rgb), 0.18)" stroke-width="4" stroke-linecap="round" fill="none"/>

              <!-- Phone in hand -->
              <rect x="84" y="38" width="18" height="28" rx="4" fill="rgba(var(--color-accent-rgb), 0.1)" stroke="rgba(var(--color-accent-rgb), 0.3)" stroke-width="1"/>
              <rect x="87" y="42" width="12" height="18" rx="2" fill="rgba(var(--color-accent-rgb), 0.15)"/>
              <circle cx="91" cy="47" r="1.5" fill="rgba(40, 200, 64, 0.6)"/>
              <rect x="95" y="46" width="4" height="2" rx="1" fill="rgba(var(--color-accent-rgb), 0.2)"/>
              <circle cx="91" cy="53" r="1.5" fill="rgba(40, 200, 64, 0.6)"/>
              <rect x="95" y="52" width="4" height="2" rx="1" fill="rgba(var(--color-accent-rgb), 0.2)"/>

              <!-- Beer -->
              <rect x="118" y="52" width="14" height="26" rx="3" fill="rgba(245, 189, 66, 0.15)" stroke="rgba(245, 189, 66, 0.35)" stroke-width="1"/>
              <rect x="120" y="58" width="10" height="18" rx="2" fill="rgba(245, 189, 66, 0.25)"/>
              <ellipse cx="125" cy="57" rx="7" ry="3" fill="rgba(255, 255, 255, 0.15)" stroke="rgba(255, 255, 255, 0.1)" stroke-width="0.5"/>
              <path d="M132 58 Q140 58, 140 66 Q140 74, 132 74" stroke="rgba(245, 189, 66, 0.3)" stroke-width="1.5" fill="none"/>
              <circle cx="123" cy="70" r="1" fill="rgba(245, 189, 66, 0.3)">
                <animate attributeName="cy" values="70;62;58" dur="2s" repeatCount="indefinite"/>
                <animate attributeName="opacity" values="0.3;0.5;0" dur="2s" repeatCount="indefinite"/>
              </circle>
              <circle cx="127" cy="68" r="0.8" fill="rgba(245, 189, 66, 0.25)">
                <animate attributeName="cy" values="68;60;56" dur="2.5s" repeatCount="indefinite"/>
                <animate attributeName="opacity" values="0.25;0.4;0" dur="2.5s" repeatCount="indefinite"/>
              </circle>

              <!-- Floating status indicators -->
              <circle cx="36" cy="24" r="4" fill="rgba(40, 200, 64, 0.1)" stroke="rgba(40, 200, 64, 0.3)" stroke-width="0.75">
                <animate attributeName="opacity" values="0.5;1;0.5" dur="3s" repeatCount="indefinite"/>
              </circle>
              <circle cx="36" cy="24" r="1.5" fill="rgba(40, 200, 64, 0.5)"/>
              <circle cx="140" cy="20" r="4" fill="rgba(40, 200, 64, 0.1)" stroke="rgba(40, 200, 64, 0.3)" stroke-width="0.75">
                <animate attributeName="opacity" values="0.5;1;0.5" dur="3.5s" repeatCount="indefinite"/>
              </circle>
              <circle cx="140" cy="20" r="1.5" fill="rgba(40, 200, 64, 0.5)"/>
              <circle cx="24" cy="52" r="3.5" fill="rgba(40, 200, 64, 0.1)" stroke="rgba(40, 200, 64, 0.3)" stroke-width="0.75">
                <animate attributeName="opacity" values="0.5;1;0.5" dur="2.8s" repeatCount="indefinite"/>
              </circle>
              <circle cx="24" cy="52" r="1.5" fill="rgba(40, 200, 64, 0.5)"/>

              <text x="80" y="116" text-anchor="middle" fill="rgba(var(--color-accent-rgb), 0.35)" font-family="var(--font-family-mono)" font-size="7">ALL SYSTEMS RUNNING</text>
            </svg>
          </div>
          <h4 class="step-title">Relax & Monitor</h4>
          <p class="step-desc">Your desktop infra runs itself. Check in from your phone while you enjoy a cold one.</p>
        </div>
      </div>

      <p class="text-xs text-theme-primary/40 mt-6">Less than a pint a month. 🍺</p>
    </div>

    <!-- Feature cards -->
    <div class="platform-grid">
      {features.map((feature) => (
        <div class="platform-card">
          <div class="platform-card-visual">
            <div set:html={feature.svg}></div>
          </div>
          <div class="platform-card-content">
            <span class="platform-card-accent">{feature.accent}</span>
            <h3 class="platform-card-title">{feature.title}</h3>
            <p class="platform-card-desc">{feature.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .platform-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: 1rem;
    padding: 0.375rem 1rem;
    border-radius: 9999px;
    background: rgba(var(--color-accent-rgb), 0.08);
    border: 1px solid rgba(var(--color-accent-rgb), 0.15);
  }

  .platform-badge-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-accent);
  }

  .platform-signin-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.75rem 1.75rem;
    border-radius: 9999px;
    font-size: 0.9375rem;
    font-weight: 600;
    color: white;
    background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-strong) 100%);
    box-shadow:
      0 0 0 1px rgba(var(--color-accent-rgb), 0.3),
      0 6px 20px rgba(var(--color-accent-rgb), 0.2),
      inset 0 1px 0 rgba(255,255,255,0.15);
    transition: all 0.3s ease;
  }

  .platform-signin-btn:hover {
    transform: translateY(-2px);
    box-shadow:
      0 0 0 1px rgba(var(--color-accent-rgb), 0.4),
      0 10px 28px rgba(var(--color-accent-rgb), 0.3),
      inset 0 1px 0 rgba(255,255,255,0.15);
  }

  /* ===== Grid ===== */
  .platform-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .platform-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .platform-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ===== Card ===== */
  .platform-card {
    display: flex;
    flex-direction: column;
    border-radius: 1rem;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    overflow: hidden;
    transition: all 0.3s ease;
    position: relative;
  }

  .platform-card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(circle at 50% 0%, rgba(var(--color-accent-rgb), 0.06) 0%, transparent 70%);
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .platform-card:hover::after { opacity: 1; }

  .platform-card:hover {
    border-color: rgba(var(--color-accent-rgb), 0.2);
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.15);
  }

  /* Last two cards span to fill row on 3-col */
  @media (min-width: 1024px) {
    .platform-card:nth-child(4) {
      grid-column: 1 / 2;
    }
    .platform-card:nth-child(5) {
      grid-column: 2 / 4;
    }
  }

  .platform-card-visual {
    padding: 1.25rem 1.25rem 0;
    height: 160px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .platform-card-visual::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 30px;
    background: linear-gradient(to top, var(--color-surface), transparent);
    pointer-events: none;
  }

  .platform-card-content {
    padding: 1rem 1.25rem 1.25rem;
  }

  .platform-card-accent {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    opacity: 0.7;
    margin-bottom: 0.375rem;
    font-family: var(--font-family-mono);
  }

  .platform-card-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 0.375rem;
    line-height: 1.3;
  }

  @media (min-width: 768px) {
    .platform-card-title {
      font-size: 1.0625rem;
    }
  }

  .platform-card-desc {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--color-secondary);
    opacity: 0.7;
  }

  @media (min-width: 768px) {
    .platform-card-desc {
      font-size: 0.875rem;
    }
  }

  /* === Onboarding hero === */
  .onboarding-hero {
    max-width: 56rem;
    margin: 0 auto 3rem;
    text-align: center;
    padding: 2rem 1.5rem;
    border-radius: 1.25rem;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    position: relative;
    overflow: hidden;
  }

  .onboarding-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 70% 50% at 50% 0%, rgba(var(--color-accent-rgb), 0.06) 0%, transparent 70%);
    pointer-events: none;
  }

  .onboarding-steps {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  @media (min-width: 768px) {
    .onboarding-steps {
      flex-direction: row;
      align-items: flex-start;
      justify-content: center;
      gap: 0;
    }
  }

  .onboarding-step {
    flex: 1;
    max-width: 220px;
    position: relative;
    text-align: center;
  }

  .step-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: rgba(var(--color-accent-rgb), 0.12);
    border: 1px solid rgba(var(--color-accent-rgb), 0.3);
    color: var(--color-accent);
    font-size: 0.75rem;
    font-weight: 700;
    font-family: var(--font-family-mono);
    margin-bottom: 0.75rem;
  }

  .step-illustration {
    width: 160px;
    height: 120px;
    margin: 0 auto 0.75rem;
  }

  .step-title {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 0.25rem;
  }

  .step-desc {
    font-size: 0.75rem;
    line-height: 1.5;
    color: var(--color-secondary);
    opacity: 0.7;
  }

  .step-connector {
    display: none;
  }

  @media (min-width: 768px) {
    .step-connector {
      display: flex;
      align-items: center;
      padding-top: 80px;
      flex-shrink: 0;
    }
  }
</style>
