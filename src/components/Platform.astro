---
const features = [
  { tag: 'workspaces', title: 'Every machine, one mesh', desc: 'Your laptop, your desktop, your cloud box — each one is a full development environment. Connect them into the harness and let agents work inside any of them with complete context.' },
  { tag: 'control', title: 'Steer from anywhere', desc: 'Review agent work, approve changes, and redirect priorities from your phone or iPad. You stay in the loop without being in the chair.' },
  { tag: 'persistence', title: 'Agents that never leave their desk', desc: 'Agents stay connected to your workspaces around the clock. No dropped sessions, no lost context. They pick up right where they left off — like a colleague who never goes home.' },
  { tag: 'reach', title: 'Any machine is a workspace', desc: 'A Raspberry Pi running your home automation. A NUC under your desk. A GPU rig in the closet. If it can run code, agents can work inside it — managed from one place.' },
  { tag: 'freedom', title: 'Bring any model', desc: "Claude, Codex, Gemini — or self-hosted via Ollama, vLLM, any OpenAI-compatible endpoint. Your subscriptions or your API keys. The harness doesn't care who's thinking, just where they're working." },
];

const onboarding = [
  { n: '01', cmd: 'molt connect', title: 'Connect your workspace', desc: 'Install the desktop app. Your machine joins the mesh — files, tools, environment and all.' },
  { n: '02', cmd: 'molt mobile', title: 'Get the mobile app', desc: 'See what your agents are doing. Review, approve, and steer — from wherever you are.' },
  { n: '03', cmd: 'molt chill', title: 'Ship while you chill', desc: 'Agents work your codebase. You review from the couch. Cold one optional but encouraged.' },
];
---

<section class="section">
  <div class="section-head">
    <span class="chip">// the.mesh</span>
    <h2 class="section-title">Your workspaces. Your models. One harness.</h2>
    <p class="section-sub">Agents need somewhere real to work — not a sandbox, but your actual environment with full context. Your machines are those workspaces. The harness connects them.</p>
    <a href="https://platform.moltcode.com" class="btn">$ sign-in.hub</a>
  </div>

  <!-- Feature grid -->
  <div class="plat-grid">
    {features.map((f) => (
      <div class="pane plat-pane">
        <div class="pane-header">
          <div class="pane-dots">
            <span class="pane-dot"></span>
            <span class="pane-dot"></span>
            <span class="pane-dot"></span>
          </div>
          <span class="pane-path">~/{f.tag}</span>
        </div>
        <div class="plat-body">
          <h3 class="plat-title">{f.title}</h3>
          <p class="plat-desc">{f.desc}</p>
        </div>
      </div>
    ))}
  </div>

  <!-- Onboarding -->
  <div class="onboard-head">
    <h3 class="onboard-title">Up and running in 3 steps.</h3>
    <p class="onboard-sub">Connect your workspace, grab the mobile app, and let the harness do the rest.</p>
  </div>

  <div class="onboard-grid">
    {onboarding.map((o) => (
      <div class="pane">
        <div class="pane-header">
          <div class="pane-dots">
            <span class="pane-dot"></span>
            <span class="pane-dot"></span>
            <span class="pane-dot"></span>
          </div>
          <span class="pane-path">step.{o.n}</span>
        </div>
        <div class="onboard-body">
          <div class="onboard-cmd"><span class="onboard-prompt">$</span> {o.cmd}</div>
          <h4 class="onboard-step-title">{o.title}</h4>
          <p class="onboard-desc">{o.desc}</p>
        </div>
      </div>
    ))}
  </div>

  <p class="onboard-foot">// less than a pint a month.</p>
</section>

<style>
  .section-head {
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.875rem;
  }

  .section-title {
    font-family: var(--font-family-sans);
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin: 0;
  }

  .section-sub {
    font-family: var(--font-family-mono);
    font-size: 13px;
    color: var(--color-secondary);
    line-height: 1.7;
    margin: 0;
    max-width: 36rem;
  }

  .plat-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-bottom: 4rem;
  }

  @media (min-width: 768px) {
    .plat-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .plat-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .plat-title {
    font-family: var(--font-family-sans);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-primary);
    margin: 0;
    letter-spacing: -0.005em;
  }

  .plat-desc {
    font-family: var(--font-family-mono);
    font-size: 12px;
    color: var(--color-secondary);
    line-height: 1.7;
    margin: 0;
  }

  .onboard-head {
    margin-bottom: 1.5rem;
  }

  .onboard-title {
    font-family: var(--font-family-sans);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-primary);
    letter-spacing: -0.01em;
    margin: 0 0 0.5rem;
  }

  .onboard-sub {
    font-family: var(--font-family-mono);
    font-size: 13px;
    color: var(--color-secondary);
    margin: 0;
  }

  .onboard-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 768px) {
    .onboard-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .onboard-body {
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .onboard-cmd {
    font-family: var(--font-family-mono);
    font-size: 11px;
    color: var(--color-muted);
    margin-bottom: 0.25rem;
  }

  .onboard-prompt {
    color: var(--color-accent);
    margin-right: 0.25rem;
  }

  .onboard-step-title {
    font-family: var(--font-family-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-primary);
    margin: 0;
    letter-spacing: -0.005em;
  }

  .onboard-desc {
    font-family: var(--font-family-mono);
    font-size: 12px;
    color: var(--color-secondary);
    line-height: 1.65;
    margin: 0;
  }

  .onboard-foot {
    margin-top: 1.5rem;
    font-family: var(--font-family-mono);
    font-size: 11px;
    color: var(--color-muted);
    text-align: center;
  }
</style>
